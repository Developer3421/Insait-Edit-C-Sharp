<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Program_Image_Editor.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <!-- Insait Edit dark palette -->
        <SolidColorBrush x:Key="AppBg"           Color="#FF1F1A24"/>
        <SolidColorBrush x:Key="PanelBg"         Color="#FF2A2230"/>
        <SolidColorBrush x:Key="TitleBarBg"      Color="#FF2D2438"/>
        <SolidColorBrush x:Key="BorderDim"       Color="#FF3E3050"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#FFF0E8F4"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#FF9E90B0"/>
        <SolidColorBrush x:Key="AccentPurple"    Color="#FF8B5CF6"/>
        <SolidColorBrush x:Key="AccentOrange"    Color="#FFFFC09F"/>
        <SolidColorBrush x:Key="AccentGreen"     Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="AccentRed"       Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="AccentCyan"      Color="#FF89DCEB"/>
        <SolidColorBrush x:Key="EditorBg"        Color="#FF1A1624"/>
        <SolidColorBrush x:Key="GutterBg"        Color="#FF241E2C"/>
        <SolidColorBrush x:Key="GutterFg"        Color="#FF9E90B0"/>
    </Application.Resources>
</Application>