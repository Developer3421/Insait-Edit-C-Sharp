<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Insait_Edit_C_Sharp.InsaitCodeEditor.InsaitEditor"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
             ClipToBounds="True" Focusable="True"
             Background="Transparent">

    <!-- ═══════════════════════════════════════════════════════════════════
         InsaitEditor — Roslyn-powered editor
         Completion + QuickFix → separate independent windows
         Only surface, scrollbars, signature/tooltip overlays here
         ═══════════════════════════════════════════════════════════════════ -->

    <UserControl.Resources>
        <SolidColorBrush x:Key="SigBg"      Color="#FF2A2230"/>
        <SolidColorBrush x:Key="BorderDim"   Color="#FF3E3050"/>
        <SolidColorBrush x:Key="DiagBorder"  Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="PopupBg"     Color="#FF201A2E"/>
        <SolidColorBrush x:Key="PurpleBorder" Color="#FF6C3FAA"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF0E8F4"/>
        <SolidColorBrush x:Key="ScrollBg"    Color="#20DCC4FF"/>
        <SolidColorBrush x:Key="ScrollFg"    Color="#60DCC4FF"/>
    </UserControl.Resources>

    <Panel>
        <!-- ── Surface + ScrollBars ────────────────────────────────────── -->
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
            <Border Grid.Row="0" Grid.Column="0" x:Name="SurfaceHost"
                    Background="Transparent"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            <ScrollBar Grid.Row="0" Grid.Column="1" x:Name="VScroll"
                       Orientation="Vertical" Width="12"
                       Background="{StaticResource ScrollBg}" Foreground="{StaticResource ScrollFg}"
                       Minimum="0" SmallChange="1"/>
            <ScrollBar Grid.Row="1" Grid.Column="0" x:Name="HScroll"
                       Orientation="Horizontal" Height="12"
                       Background="{StaticResource ScrollBg}" Foreground="{StaticResource ScrollFg}"
                       Minimum="0" SmallChange="10"/>
        </Grid>

        <!-- ── Lightweight overlays (signature + diagnostic tooltip) ── -->
        <Canvas IsHitTestVisible="False">
            <!-- Ready badge -->
            <Border x:Name="ReadyBadge" Background="#FF8B5CF6"
                    CornerRadius="0,0,6,0" Padding="12,4"
                    IsVisible="False" Canvas.Left="0" Canvas.Top="0">
                <TextBlock Text="✦ Insait · Roslyn IntelliSense"
                           FontSize="11" FontWeight="SemiBold" Foreground="#FFF0E8F4"/>
            </Border>

            <!-- Signature help -->
            <Border x:Name="SignaturePopup" Background="{StaticResource SigBg}"
                    BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                    CornerRadius="6" Padding="10,6" BoxShadow="0 3 12 0 #40000000"
                    IsVisible="False">
                <TextBlock x:Name="SignatureText"
                           FontFamily="Cascadia Code, Consolas, monospace" FontSize="12"
                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" MaxWidth="500"/>
            </Border>

            <!-- Diagnostic tooltip -->
            <Border x:Name="TooltipPopup" Background="{StaticResource PopupBg}"
                    BorderBrush="{StaticResource DiagBorder}" BorderThickness="1"
                    CornerRadius="4" Padding="8,4" BoxShadow="0 2 8 0 #30000000"
                    IsVisible="False">
                <TextBlock x:Name="TooltipText"
                           FontFamily="Cascadia Code, Consolas, monospace" FontSize="11"
                           Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" MaxWidth="450"/>
            </Border>
        </Canvas>
    </Panel>
</UserControl>

