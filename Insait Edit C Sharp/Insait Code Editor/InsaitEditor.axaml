<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Insait_Edit_C_Sharp.InsaitCodeEditor.InsaitEditor"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
             ClipToBounds="True" Focusable="True"
             Background="Transparent">

    <!-- ═══════════════════════════════════════════════════════════════════
         InsaitEditor — Amber Fluent Code Editor
         UI layout: Surface + ScrollBars + Overlay Popups
         ═══════════════════════════════════════════════════════════════════ -->

    <UserControl.Resources>
        <!-- Purple Fluent palette brushes -->
        <SolidColorBrush x:Key="AmberBg"        Color="#FF1F1A24"/>
        <SolidColorBrush x:Key="AmberPopupBg"    Color="#FF1F1A24"/>
        <SolidColorBrush x:Key="AmberBorder"     Color="#FF3E3050"/>
        <SolidColorBrush x:Key="AmberOrange"     Color="#FF8B5CF6"/>
        <SolidColorBrush x:Key="AmberText"       Color="#FFF0E8F4"/>
        <SolidColorBrush x:Key="AmberBadgeText"  Color="#FFF0E8F4"/>
        <SolidColorBrush x:Key="AmberFixBg"      Color="#FF2A2230"/>
        <SolidColorBrush x:Key="AmberFixBorder"  Color="#FF7C3AED"/>
        <SolidColorBrush x:Key="AmberSigBg"      Color="#FF2A2230"/>
        <SolidColorBrush x:Key="AmberDiagBorder" Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="ScrollBg"        Color="#20DCC4FF"/>
        <SolidColorBrush x:Key="ScrollFg"        Color="#60DCC4FF"/>
    </UserControl.Resources>

    <!-- ListBox item styles — prevent Fluent theme white backgrounds -->
    <UserControl.Styles>
        <Style Selector="ListBox#CompletionList ListBoxItem">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#CompletionList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#40DCC4FF"/>
        </Style>
        <Style Selector="ListBox#CompletionList ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#25DCC4FF"/>
        </Style>

        <Style Selector="ListBox#QuickFixList ListBoxItem">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBox#QuickFixList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#40DCC4FF"/>
        </Style>
        <Style Selector="ListBox#QuickFixList ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#25DCC4FF"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- ── Main grid: Surface + ScrollBars ─────────────────────────── -->
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">

            <!-- Editor rendering surface (InsaitEditorSurface lives here via code-behind) -->
            <Border Grid.Row="0" Grid.Column="0"
                    x:Name="SurfaceHost"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

            <!-- Vertical scroll bar -->
            <ScrollBar Grid.Row="0" Grid.Column="1"
                       x:Name="VScroll"
                       Orientation="Vertical"
                       Width="12"
                       Background="{StaticResource ScrollBg}"
                       Foreground="{StaticResource ScrollFg}"
                       Minimum="0" SmallChange="1"/>

            <!-- Horizontal scroll bar -->
            <ScrollBar Grid.Row="1" Grid.Column="0"
                       x:Name="HScroll"
                       Orientation="Horizontal"
                       Height="12"
                       Background="{StaticResource ScrollBg}"
                       Foreground="{StaticResource ScrollFg}"
                       Minimum="0" SmallChange="10"/>
        </Grid>

        <!-- ══ Overlay Canvas for popups (не перехоплює хіт-тест) ══════ -->
        <Canvas IsHitTestVisible="False">

            <!-- Ready badge -->
            <Border x:Name="ReadyBadge"
                    Background="#FF8B5CF6"
                    CornerRadius="0,0,6,0"
                    Padding="12,4"
                    IsVisible="False"
                    Canvas.Left="0" Canvas.Top="0">
                <TextBlock Text="✦ Insait Code Editor · Roslyn готовий"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#FFF0E8F4"/>
            </Border>

            <!-- ── Completion popup ──────────────────────────────────── -->
            <Border x:Name="CompletionPopup"
                    Background="{StaticResource AmberPopupBg}"
                    BorderBrush="{StaticResource AmberBorder}"
                    BorderThickness="1" CornerRadius="6"
                    BoxShadow="0 4 20 0 #50000000"
                    IsVisible="False">
                <ListBox x:Name="CompletionList"
                         Background="{StaticResource AmberPopupBg}"
                         Foreground="{StaticResource AmberText}"
                         MaxHeight="220" MinWidth="300"
                         Focusable="False"
                         BorderThickness="0"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="12"/>
            </Border>

            <!-- ── Quick fix popup ───────────────────────────────────── -->
            <Border x:Name="QuickFixPopup"
                    Background="{StaticResource AmberFixBg}"
                    BorderBrush="{StaticResource AmberFixBorder}"
                    BorderThickness="1" CornerRadius="6"
                    BoxShadow="0 4 20 0 #50000000"
                    IsVisible="False">
                <ListBox x:Name="QuickFixList"
                         Background="{StaticResource AmberFixBg}"
                         Foreground="{StaticResource AmberText}"
                         MaxHeight="180" MinWidth="320"
                         Focusable="False"
                         BorderThickness="0"
                         FontFamily="Cascadia Code, Consolas, monospace"
                         FontSize="12"/>
            </Border>

            <!-- ── Signature help popup ──────────────────────────────── -->
            <Border x:Name="SignaturePopup"
                    Background="{StaticResource AmberSigBg}"
                    BorderBrush="{StaticResource AmberBorder}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="10,6"
                    BoxShadow="0 3 12 0 #40000000"
                    IsVisible="False">
                <TextBlock x:Name="SignatureText"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="12"
                           Foreground="{StaticResource AmberText}"
                           TextWrapping="Wrap" MaxWidth="500"/>
            </Border>

            <!-- ── Diagnostic tooltip (hover) ────────────────────────── -->
            <Border x:Name="TooltipPopup"
                    Background="{StaticResource AmberPopupBg}"
                    BorderBrush="{StaticResource AmberDiagBorder}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="8,4"
                    BoxShadow="0 2 8 0 #30000000"
                    IsVisible="False">
                <TextBlock x:Name="TooltipText"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="11"
                           Foreground="{StaticResource AmberText}"
                           TextWrapping="Wrap" MaxWidth="450"/>
            </Border>
        </Canvas>
    </Panel>
</UserControl>

