<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="Insait_Edit_C_Sharp.AxamlPreviewWindow"
        Title="AXAML Preview"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Width="1000"
        Height="720"
        MinWidth="500"
        MinHeight="400"
        CanResize="True"
        UseLayoutRounding="True"
        FontFamily="Segoe UI, Arial, Tahoma"
        Background="#FF1F1A24">

    <Window.Styles>
        <Style Selector="Button.win-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.win-btn:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
        </Style>
        <Style Selector="Button.tool-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.tool-btn:pointerover">
            <Setter Property="Background" Value="#20FFFFFF"/>
        </Style>
        <Style Selector="Button.err-btn">
            <Setter Property="Background" Value="#25F38BA8"/>
            <Setter Property="BorderBrush" Value="#50F38BA8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.err-btn:pointerover">
            <Setter Property="Background" Value="#40F38BA8"/>
        </Style>
    </Window.Styles>

    <!-- 3 rows: title bar | toolbar | preview area -->
    <Grid RowDefinitions="36,Auto,*">

        <!-- ── Title Bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#FF2D2438"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="🎨" FontSize="15" FontFamily="Segoe UI Emoji"
                               VerticalAlignment="Center"/>
                    <TextBlock Name="TitleText" Text="AXAML Preview"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#FFFFC09F" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0"
                            VerticalAlignment="Center">
                    <Button Classes="win-btn" Width="36" Height="36" Click="Minimize_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/MinButton.png"
                               Width="24" Height="24"/>
                    </Button>
                    <Button Classes="win-btn" Width="36" Height="36" Click="MaximizeRestore_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/MaxButton.png"
                               Width="24" Height="24"/>
                    </Button>
                    <Button Classes="win-btn" Width="36" Height="36" Click="Close_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png"
                               Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Toolbar ───────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#FF2A2230" Padding="8,5"
                BorderBrush="#FF3E3050" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Left: file name -->
                <TextBlock Grid.Column="0" Name="FileNameLabel" Text="—"
                           FontSize="12" Foreground="#FF9E90B0"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <!-- Centre: tools -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">

                    <Border Width="1" Background="#FF3E3050" Margin="2,2"/>

                    <!-- Refresh -->
                    <Button Classes="tool-btn" ToolTip.Tip="Refresh (F5)"
                            Click="Refresh_Click" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="🔄" FontSize="12" FontFamily="Segoe UI Emoji"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Refresh" FontSize="11" Foreground="#FFF0E8F4"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="#FF3E3050" Margin="2,2"/>

                    <!-- Size presets -->
                    <TextBlock Text="Size:" FontSize="11" Foreground="#FF9E90B0"
                               VerticalAlignment="Center"/>
                    <Button Classes="tool-btn" ToolTip.Tip="Phone 360×640"
                            Click="SizePhone_Click" Padding="6,4">
                        <TextBlock Text="📱" FontSize="12" FontFamily="Segoe UI Emoji"/>
                    </Button>
                    <Button Classes="tool-btn" ToolTip.Tip="Tablet 768×1024"
                            Click="SizeTablet_Click" Padding="6,4">
                        <TextBlock Text="💻" FontSize="12" FontFamily="Segoe UI Emoji"/>
                    </Button>
                    <Button Classes="tool-btn" ToolTip.Tip="Desktop 1280×800"
                            Click="SizeDesktop_Click" Padding="6,4">
                        <TextBlock Text="🖥️" FontSize="12" FontFamily="Segoe UI Emoji"/>
                    </Button>
                    <Button Classes="tool-btn" ToolTip.Tip="Fill area"
                            Click="SizeFill_Click" Padding="6,4">
                        <TextBlock Text="⬛" FontSize="12" FontFamily="Segoe UI Emoji"/>
                    </Button>
                    <TextBlock Name="SizeLabel" Text="Free"
                               FontSize="11" Foreground="#FF9E90B0"
                               VerticalAlignment="Center" Margin="2,0"/>

                    <Border Width="1" Background="#FF3E3050" Margin="2,2"/>

                    <!-- BG toggle -->
                    <Button Classes="tool-btn" ToolTip.Tip="Toggle background"
                            Click="ToggleBackground_Click" Padding="6,4">
                        <TextBlock Text="🎨" FontSize="12" FontFamily="Segoe UI Emoji"/>
                    </Button>
                </StackPanel>

                <!-- Right: status + error button -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">

                    <TextBlock Name="StatusLabel" Text="Ready"
                               FontSize="11" Foreground="#FFA6E3A1"
                               VerticalAlignment="Center"/>

                    <!-- Error button — only visible when there is an error -->
                    <Button Name="ErrorButton" Classes="err-btn"
                            IsVisible="False"
                            ToolTip.Tip="Show error details"
                            Click="ErrorButton_Click" Padding="8,3">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="⚠" FontSize="12" FontFamily="Segoe UI Emoji"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Error" FontSize="11" Foreground="#FFF38BA8"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Preview area ──────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#FF181420" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Border Name="PreviewCanvas"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#FF1F1A24"
                        BoxShadow="0 4 32 0 #80000000"
                        Margin="24">
                    <ContentControl Name="PreviewContent"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"/>
                </Border>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>

