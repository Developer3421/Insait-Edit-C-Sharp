<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.ProjectPropertiesWindow"
        Title="Project Properties"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        SystemDecorations="None"
        Background="#FF1F1A24">

    <Window.Styles>
        <!-- Action buttons -->
        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-button:pointerover">
            <Setter Property="Background" Value="#FF4A3D58"/>
        </Style>
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="#FFFFC09F"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-button:pointerover">
            <Setter Property="Background" Value="#FFFFD4B8"/>
        </Style>
        <!-- Left nav item -->
        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF9E90B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.nav-button:pointerover">
            <Setter Property="Background" Value="#15DCC4FF"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
        </Style>
        <Style Selector="Button.nav-button.active">
            <Setter Property="Background" Value="#30FFC09F"/>
            <Setter Property="Foreground" Value="#FFFFC09F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FF352840"/>
        </Style>
        <!-- ComboBox -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="#FF2A2230"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
        </Style>
        <!-- CheckBox -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
        <!-- Section header -->
        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF9E90B0"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>
        <!-- Label -->
        <Style Selector="TextBlock.prop-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Styles>

    <Border BorderBrush="#FF3E3050" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="36,*,Auto">

            <!-- â”€â”€ Title Bar â”€â”€ -->
            <Border Grid.Row="0" Background="#FF2D2438" CornerRadius="8,8,0,0" Name="TitleBar">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="12,0">
                        <TextBlock Text="⚙️" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Name="TitleText" Text="Project Properties" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FFF0E8F4" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Name="CloseButton"
                            Background="Transparent" Foreground="#FF9E90B0"
                            BorderThickness="0" Width="36" Height="36"
                            Cursor="Hand" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- â”€â”€ Main Body â”€â”€ -->
            <Grid Grid.Row="1" ColumnDefinitions="180,1,*">

                <!-- Left Navigation -->
                <Border Grid.Column="0" Background="#FF241E2C" Padding="8,12">
                    <StackPanel Spacing="2">
                        <Button Name="NavGeneral"   Classes="nav-button active" Content="⚙️  General"/>
                        <Button Name="NavBuild"     Classes="nav-button"        Content="🔨  Build"/>
                        <Button Name="NavPackage"   Classes="nav-button"        Content="📦  Package / NuGet"/>
                        <Button Name="NavSign"      Classes="nav-button"        Content="🔏  Signing"/>
                        <Button Name="NavDebug"     Classes="nav-button"        Content="🐛  Debug"/>
                    </StackPanel>
                </Border>

                <!-- Divider -->
                <Border Grid.Column="1" Background="#FF3E3050"/>

                <!-- Right Content area -->
                <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto" Padding="24,16">
                    <StackPanel Spacing="0">

                        <!-- â•â• GENERAL SECTION â•â• -->
                        <StackPanel Name="PanelGeneral">
                            <TextBlock Text="GENERAL" Classes="section-header"/>

                            <!-- Assembly name -->
                            <TextBlock Text="Assembly name" Classes="prop-label"/>
                            <TextBox Name="AssemblyNameBox" Watermark="e.g. MyApp" Margin="0,0,0,12"/>

                            <!-- Default namespace -->
                            <TextBlock Text="Default namespace" Classes="prop-label"/>
                            <TextBox Name="DefaultNamespaceBox" Watermark="e.g. MyApp" Margin="0,0,0,12"/>

                            <!-- Target framework(s) -->
                            <TextBlock Text="Target framework" Classes="prop-label"/>
                            <ComboBox Name="TargetFrameworkCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="net10.0"/>
                                <ComboBoxItem Content="net9.0"/>
                                <ComboBoxItem Content="net8.0"/>
                                <ComboBoxItem Content="net7.0"/>
                                <ComboBoxItem Content="net6.0"/>
                                <ComboBoxItem Content="net5.0"/>
                                <ComboBoxItem Content="netcoreapp3.1"/>
                                <ComboBoxItem Content="netstandard2.1"/>
                                <ComboBoxItem Content="netstandard2.0"/>
                                <ComboBoxItem Content="net48"/>
                                <ComboBoxItem Content="net472"/>
                                <ComboBoxItem Content="net462"/>
                            </ComboBox>

                            <!-- Output type -->
                            <TextBlock Text="Output type" Classes="prop-label"/>
                            <ComboBox Name="OutputTypeCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="Console Application" Tag="Exe"/>
                                <ComboBoxItem Content="Windows Application" Tag="WinExe"/>
                                <ComboBoxItem Content="Class Library" Tag="Library"/>
                            </ComboBox>

                            <!-- Language version -->
                            <TextBlock Text="C# language version" Classes="prop-label"/>
                            <ComboBox Name="LangVersionCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="Default (latest major)"/>
                                <ComboBoxItem Content="Latest"/>
                                <ComboBoxItem Content="preview"/>
                                <ComboBoxItem Content="13"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="11"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="9.0"/>
                                <ComboBoxItem Content="8.0"/>
                                <ComboBoxItem Content="7.3"/>
                            </ComboBox>

                            <!-- Nullable -->
                            <TextBlock Text="Nullable reference types" Classes="prop-label"/>
                            <ComboBox Name="NullableCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="enable"/>
                                <ComboBoxItem Content="disable"/>
                                <ComboBoxItem Content="warnings"/>
                                <ComboBoxItem Content="annotations"/>
                            </ComboBox>

                            <!-- Implicit usings -->
                            <CheckBox Name="ImplicitUsingsCheck" Content="Enable implicit usings" Margin="0,0,0,12"/>

                            <!-- Nullable -->
                            <CheckBox Name="AllowUnsafeCheck" Content="Allow unsafe code" Margin="0,0,0,12"/>

                            <!-- Root namespace separator -->
                            <Border Height="1" Background="#FF3E3050" Margin="0,8,0,0"/>
                            <TextBlock Text="APPLICATION" Classes="section-header"/>

                            <!-- Startup object -->
                            <TextBlock Text="Startup object" Classes="prop-label"/>
                            <TextBox Name="StartupObjectBox" Watermark="(default)" Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- â•â• BUILD SECTION â•â• -->
                        <StackPanel Name="PanelBuild" IsVisible="False">
                            <TextBlock Text="BUILD" Classes="section-header"/>

                            <TextBlock Text="Configuration" Classes="prop-label"/>
                            <ComboBox Name="ConfigurationCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="Debug"/>
                                <ComboBoxItem Content="Release"/>
                            </ComboBox>

                            <TextBlock Text="Platform" Classes="prop-label"/>
                            <ComboBox Name="PlatformCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="Any CPU"/>
                                <ComboBoxItem Content="x64"/>
                                <ComboBoxItem Content="x86"/>
                                <ComboBoxItem Content="ARM64"/>
                            </ComboBox>

                            <Border Height="1" Background="#FF3E3050" Margin="0,4,0,0"/>
                            <TextBlock Text="COMPILER OPTIONS" Classes="section-header"/>

                            <CheckBox Name="OptimizeCheck" Content="Optimize code" Margin="0,0,0,8"/>
                            <CheckBox Name="WarningsAsErrorsCheck" Content="Treat warnings as errors" Margin="0,0,0,8"/>

                            <TextBlock Text="Warning level" Classes="prop-label" Margin="0,8,0,4"/>
                            <ComboBox Name="WarningLevelCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="0 — No warnings"/>
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4 (default)"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>

                            <TextBlock Text="Suppress specific warnings (semicolon-separated)" Classes="prop-label"/>
                            <TextBox Name="NoWarnBox" Watermark="e.g. CS1591;CS0618" Margin="0,0,0,12"/>

                            <Border Height="1" Background="#FF3E3050" Margin="0,4,0,0"/>
                            <TextBlock Text="OUTPUT" Classes="section-header"/>

                            <TextBlock Text="Output path" Classes="prop-label"/>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <TextBox Name="OutputPathBox" Grid.Column="0" Watermark="bin\$(Configuration)\"/>
                                <Button Grid.Column="1" Name="BrowseOutputButton" Content="..." Width="36"
                                        Classes="action-button" Margin="4,0,0,0"/>
                            </Grid>

                            <TextBlock Text="Intermediate output path" Classes="prop-label"/>
                            <TextBox Name="IntermediateOutputPathBox" Watermark="obj\" Margin="0,0,0,12"/>

                            <CheckBox Name="GenerateDocXmlCheck" Content="Generate XML documentation file" Margin="0,0,0,8"/>
                        </StackPanel>

                        <!-- â•â• PACKAGE SECTION â•â• -->
                        <StackPanel Name="PanelPackage" IsVisible="False">
                            <TextBlock Text="PACKAGE / NUGET" Classes="section-header"/>

                            <CheckBox Name="GeneratePackageCheck" Content="Generate NuGet package on build" Margin="0,0,0,12"/>

                            <TextBlock Text="Package ID" Classes="prop-label"/>
                            <TextBox Name="PackageIdBox" Watermark="e.g. MyCompany.MyLib" Margin="0,0,0,12"/>

                            <TextBlock Text="Package version" Classes="prop-label"/>
                            <TextBox Name="PackageVersionBox" Watermark="1.0.0" Margin="0,0,0,12"/>

                            <TextBlock Text="Authors" Classes="prop-label"/>
                            <TextBox Name="AuthorsBox" Watermark="Author Name" Margin="0,0,0,12"/>

                            <TextBlock Text="Company" Classes="prop-label"/>
                            <TextBox Name="CompanyBox" Watermark="My Company" Margin="0,0,0,12"/>

                            <TextBlock Text="Product" Classes="prop-label"/>
                            <TextBox Name="ProductBox" Watermark="My Product" Margin="0,0,0,12"/>

                            <TextBlock Text="Description" Classes="prop-label"/>
                            <TextBox Name="PackageDescriptionBox" Watermark="Short description" Height="72"
                                     AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <TextBlock Text="Repository URL" Classes="prop-label"/>
                            <TextBox Name="RepositoryUrlBox" Watermark="https://github.com/..." Margin="0,0,0,12"/>

                            <TextBlock Text="License expression (SPDX)" Classes="prop-label"/>
                            <TextBox Name="LicenseExpressionBox" Watermark="MIT" Margin="0,0,0,12"/>

                            <TextBlock Text="Tags (semicolon-separated)" Classes="prop-label"/>
                            <TextBox Name="PackageTagsBox" Watermark="tag1;tag2" Margin="0,0,0,12"/>
                        </StackPanel>

                        <!-- â•â• SIGNING SECTION â•â• -->
                        <StackPanel Name="PanelSign" IsVisible="False">
                            <TextBlock Text="ASSEMBLY SIGNING" Classes="section-header"/>

                            <CheckBox Name="SignAssemblyCheck" Content="Sign the assembly" Margin="0,0,0,12"/>

                            <StackPanel Name="SignDetailsPanel" IsVisible="False" Spacing="0">
                                <TextBlock Text="Strong name key file (.snk / .pfx)" Classes="prop-label"/>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                    <TextBox Name="KeyFileBox" Grid.Column="0" Watermark="Path to .snk file"/>
                                    <Button Grid.Column="1" Name="BrowseKeyButton" Content="..." Width="36"
                                            Classes="action-button" Margin="4,0,0,0"/>
                                </Grid>
                                <CheckBox Name="DelaySignCheck" Content="Delay sign only" Margin="0,0,0,8"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- â•â• DEBUG SECTION â•â• -->
                        <StackPanel Name="PanelDebug" IsVisible="False">
                            <TextBlock Text="DEBUG" Classes="section-header"/>

                            <TextBlock Text="Launch profile" Classes="prop-label"/>
                            <ComboBox Name="DebugLaunchProfileCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                <ComboBoxItem Content="Project"/>
                                <ComboBoxItem Content="IIS Express"/>
                            </ComboBox>

                            <TextBlock Text="Application arguments" Classes="prop-label"/>
                            <TextBox Name="DebugArgsBox" Watermark="Command line arguments" Margin="0,0,0,12"/>

                            <TextBlock Text="Working directory" Classes="prop-label"/>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                                <TextBox Name="DebugWorkingDirBox" Grid.Column="0" Watermark="Project directory"/>
                                <Button Grid.Column="1" Name="BrowseDebugDirButton" Content="..." Width="36"
                                        Classes="action-button" Margin="4,0,0,0"/>
                            </Grid>

                            <CheckBox Name="EnableNativeDebugCheck" Content="Enable native code debugging" Margin="0,0,0,8"/>
                            <CheckBox Name="EnableSqlDebugCheck" Content="Enable SQL Server debugging" Margin="0,0,0,8"/>

                            <Border Height="1" Background="#FF3E3050" Margin="0,8,0,0"/>
                            <TextBlock Text="ENVIRONMENT VARIABLES" Classes="section-header"/>
                            <TextBlock Text="Set environment variables for the debug process:" FontSize="11"
                                       Foreground="#FF9E90B0" Margin="0,0,0,8"/>

                            <!-- Environment variables grid-like display -->
                            <Border Background="#FF2A2230" CornerRadius="6" Padding="0" Margin="0,0,0,8">
                                <Grid RowDefinitions="Auto,*">
                                    <!-- Header -->
                                    <Grid Grid.Row="0" ColumnDefinitions="*,*,Auto"
                                          Background="#FF352840" Margin="0,0,0,0">
                                        <TextBlock Grid.Column="0" Text="Name" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FF9E90B0" Margin="10,6"/>
                                        <TextBlock Grid.Column="1" Text="Value" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#FF9E90B0" Margin="10,6"/>
                                        <Button Grid.Column="2" Name="AddEnvVarDebugButton" Content="+" Width="28"
                                                Classes="action-button" Margin="4" Padding="0"
                                                ToolTip.Tip="Add environment variable"/>
                                    </Grid>
                                    <ItemsControl Grid.Row="1" Name="EnvVarsList" Margin="0,4"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- â”€â”€ Footer â”€â”€ -->
            <Border Grid.Row="2" Background="#FF2A2230" BorderBrush="#FF3E3050"
                    BorderThickness="0,1,0,0" Padding="16,10">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <!-- Status / info -->
                    <TextBlock Name="StatusLabel" Grid.Column="0" Text="" FontSize="11"
                               Foreground="#FF9E90B0" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Name="ApplyButton"  Content="Apply"  Classes="action-button"  Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Name="OkButton"     Content="OK"     Classes="primary-button" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Name="CancelButton" Content="Cancel" Classes="action-button"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>

