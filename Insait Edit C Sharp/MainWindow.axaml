<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Insait_Edit_C_Sharp.ViewModels"
        xmlns:models="using:Insait_Edit_C_Sharp.Models"
        xmlns:controls="using:Insait_Edit_C_Sharp.Controls"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Insait_Edit_C_Sharp.MainWindow"
        x:DataType="vm:MainViewModel"
        x:Name="MainWindowRoot"
        Title="Insait Edit - C# IDE"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="600"
        CanResize="True"
        UseLayoutRounding="True"
        FontFamily="Segoe UI, Arial, Tahoma">

    <!-- LOCAL RESOURCES -->
    <Window.Resources>
        <!-- Color palette - IDE Dark Theme -->
        <Color x:Key="AppBgColor">#FF1E1E2E</Color>
        <Color x:Key="AppSurfaceColor">#FF2D2D3D</Color>
        <Color x:Key="AppBorderColor">#FF3D3D4D</Color>
        <Color x:Key="AppTextColor">#FFCDD6F4</Color>
        <Color x:Key="AppTextMutedColor">#FF9399B2</Color>

        <!-- Orange is now PRIMARY accent -->
        <Color x:Key="AccentOrangeColor">#FFFAB387</Color>
        <Color x:Key="AccentOrangeHoverColor">#FFFFC09F</Color>
        <Color x:Key="AccentPurpleColor">#FFCBA6F7</Color>
        <Color x:Key="AccentPurpleHoverColor">#FFE0C0FF</Color>
        <Color x:Key="AccentGreenColor">#FFA6E3A1</Color>
        <Color x:Key="AccentBlueColor">#FF89B4FA</Color>
        <Color x:Key="AccentRedColor">#FFF38BA8</Color>

        <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
        <SolidColorBrush x:Key="AppTextBrush" Color="{StaticResource AppTextColor}" />
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMutedColor}" />

        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}" />
        <SolidColorBrush x:Key="AccentOrangeHoverBrush" Color="{StaticResource AccentOrangeHoverColor}" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}" />
        <SolidColorBrush x:Key="AccentPurpleHoverBrush" Color="{StaticResource AccentPurpleHoverColor}" />
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRedColor}" />

        <!-- Title Bar - Solid Gray -->
        <SolidColorBrush x:Key="TitleBarGradient" Color="#FF3C3C3C"/>
        
        <!-- Sidebar Gradient -->
        <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF232334" Offset="0"/>
            <GradientStop Color="#FF1E1E2E" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <!-- LOCAL STYLES -->
    <Window.Styles>
        <!-- Window Control Buttons -->
        <Style Selector="Button.window-control">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        <Style Selector="Button.window-control.close:pointerover">
            <Setter Property="Background" Value="#E81123"/>
        </Style>

        <!-- Toolbar button style -->
        <Style Selector="Button.toolbar-button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.toolbar-button:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
        <Style Selector="Button.toolbar-button:pressed">
            <Setter Property="Background" Value="#40FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>

        <!-- Primary button style -->
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-button:pointerover">
            <Setter Property="Background" Value="#FFFFC09F"/>
        </Style>
        <Style Selector="Button.primary-button:pressed">
            <Setter Property="Background" Value="#FFE09070"/>
        </Style>

        <!-- Icon button style -->
        <Style Selector="Button.icon-button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.icon-button:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        <Style Selector="Button.icon-button:pressed">
            <Setter Property="Background" Value="#60FFFFFF"/>
        </Style>
        
        <!-- Sidebar button style -->
        <Style Selector="Button.sidebar-button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Button.sidebar-button:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
        </Style>
        <Style Selector="Button.sidebar-button.active">
            <Setter Property="Background" Value="#30FAB387"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,2,0"/>
        </Style>

        <!-- Panels -->
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- Tab style -->
        <Style Selector="Button.tab-button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0,2,0,0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.tab-button:pointerover">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="BorderBrush" Value="#50FAB387"/>
        </Style>
        <Style Selector="Button.tab-button.active">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
        
        <!-- TreeView style -->
        <Style Selector="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <!-- Tool Window Tab (JetBrains Rider Style) -->
        <Style Selector="Button.tool-window-tab">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.tool-window-tab:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
        </Style>
        <Style Selector="Button.tool-window-tab.active">
            <Setter Property="Background" Value="#FF4E5254"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
        <Style Selector="Button.tool-window-tab:pressed">
            <Setter Property="Background" Value="#FF5A5D5F"/>
        </Style>
        
        <!-- Tool Action Button (for toolbar) -->
        <Style Selector="Button.tool-action-button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.tool-action-button:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
        </Style>
        <Style Selector="Button.tool-action-button:pressed">
            <Setter Property="Background" Value="#60FFFFFF"/>
        </Style>
        
        <!-- Status Bar Button (JetBrains Rider Style) -->
        <Style Selector="Button.status-bar-button">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.status-bar-button:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
        </Style>
        <Style Selector="Button.status-bar-button:pressed">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        
        <!-- GridSplitter style -->
        <Style Selector="GridSplitter.tool-splitter">
            <Setter Property="Background" Value="#FF3C3F41"/>
            <Setter Property="Cursor" Value="SizeNorthSouth"/>
        </Style>
        <Style Selector="GridSplitter.tool-splitter:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
    </Window.Styles>

    <!-- Window Background -->
    <Window.Background>
        <SolidColorBrush Color="{StaticResource AppBgColor}"/>
    </Window.Background>

    <!-- Root grid -->
    <Grid RowDefinitions="36,*,24">

        <!-- ROW 0: TITLE BAR (custom chrome) -->
        <Grid Grid.Row="0" Height="36" Background="{StaticResource TitleBarGradient}">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <!-- Left: App icon and title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="8">
                    <Border Width="20" Height="20" CornerRadius="4" Background="{StaticResource AccentOrangeBrush}">
                        <TextBlock Text="⚡" FontSize="12" Foreground="#1E1E2E" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Insait Edit"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentOrangeBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Menu and Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0" Spacing="2">
                    <!-- Main Menu Button -->
                    <Button Name="MainMenuButton" ToolTip.Tip="Menu"
                            Click="MainMenu_Click"
                            Background="#FF3D3D4D" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="12,4"
                            Height="28"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="☰" FontSize="14"/>
                            <TextBlock Text="Menu" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Separator -->
                    <Border Width="1" Height="20" Background="#FF505053" Margin="8,0"/>
                    
                    <!-- Build Button -->
                    <Button Name="BuildProjectButton" ToolTip.Tip="Build Project (Ctrl+Shift+B)"
                            Click="BuildProject_Click"
                            Background="#FF4CAF50" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="12,4"
                            Height="28"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🔨" FontSize="12"/>
                            <TextBlock Text="Build" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Analyze Button -->
                    <Button Name="AnalyzeProjectButton" ToolTip.Tip="Analyze Code (Ctrl+Shift+A)"
                            Click="AnalyzeProject_Click"
                            Background="#FF9C27B0" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="12,4"
                            Height="28"
                            Cursor="Hand"
                            Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🔍" FontSize="12"/>
                            <TextBlock Text="Analyze" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Run Configuration Selector (JetBrains Rider Style) -->
                    <Border Background="#FF3D3D4D" CornerRadius="4" Height="28" Margin="4,0,0,0" Padding="4,0">
                        <Grid ColumnDefinitions="Auto,Auto,Auto">
                            <!-- Configuration Name -->
                            <Button Name="RunConfigDropdownButton" ToolTip.Tip="Select Run Configuration (Shift+Alt+F10)"
                                    Click="RunConfigDropdown_Click"
                                    Background="Transparent" 
                                    Foreground="White"
                                    BorderThickness="0"
                                    Padding="8,0"
                                    Height="26"
                                    Cursor="Hand">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="▶" FontSize="10" Foreground="#FFA6E3A1" VerticalAlignment="Center"/>
                                    <TextBlock Text="Default" FontSize="11" Name="RunConfigNameText" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="▼" FontSize="8" Foreground="#FF9399B2" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Separator -->
                            <Border Grid.Column="1" Width="1" Height="16" Background="#FF505053" Margin="2,0"/>
                            
                            <!-- Edit Configurations Button -->
                            <Button Grid.Column="2" Name="EditConfigurationsButton" ToolTip.Tip="Edit Configurations..."
                                    Click="EditConfigurations_Click"
                                    Background="Transparent" 
                                    Foreground="#FF9399B2"
                                    BorderThickness="0"
                                    Padding="6,0"
                                    Height="26"
                                    Cursor="Hand">
                                <TextBlock Text="⚙" FontSize="12"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Run Button -->
                    <Button Name="RunProjectButton" ToolTip.Tip="Run Project (F5)"
                            Click="RunProject_Click"
                            Background="#FF4CAF50" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="10,4"
                            Height="28"
                            Cursor="Hand"
                            Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="▶" FontSize="12"/>
                            <TextBlock Text="Run" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Debug Button -->
                    <Button Name="DebugProjectButton" ToolTip.Tip="Debug Project (F5 with debugger)"
                            Click="DebugProject_Click"
                            Background="#FF9C27B0" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="8,4"
                            Height="28"
                            Cursor="Hand"
                            Margin="2,0,0,0">
                        <TextBlock Text="🐛" FontSize="12"/>
                    </Button>
                    
                    <!-- Stop Button (hidden by default) -->
                    <Button Name="CancelBuildButton" ToolTip.Tip="Stop (Shift+F5)"
                            Click="CancelBuild_Click"
                            Background="#FFF44336" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="8,4"
                            Height="28"
                            Cursor="Hand"
                            IsVisible="False"
                            Margin="2,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="⏹" FontSize="11"/>
                            <TextBlock Text="Stop" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Separator -->
                    <Border Width="1" Height="20" Background="#FF505053" Margin="8,0"/>
                    
                    <!-- Publish Button -->
                    <Button Name="PublishButton" ToolTip.Tip="Publish Project..."
                            Click="Publish_Click"
                            Background="#FF2196F3" 
                            Foreground="White"
                            CornerRadius="4"
                            Padding="10,4"
                            Height="28"
                            Cursor="Hand">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📦" FontSize="11"/>
                            <TextBlock Text="Publish" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Middle: draggable area -->
                <Panel Grid.Column="2" Background="Transparent" PointerPressed="TitleBar_PointerPressed"/>

                <!-- Right: window controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="MinimizeButton" Classes="window-control" Padding="0" Click="MinimizeButton_Click">
                        <TextBlock Text="─" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Name="MaximizeButton" Classes="window-control" Padding="0" Click="MaximizeButton_Click">
                        <TextBlock Text="□" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button Name="CloseButton" Classes="window-control close" Padding="0" Click="CloseButton_Click">
                        <TextBlock Text="✕" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ROW 1: MAIN CONTENT -->
        <Grid Grid.Row="1" ColumnDefinitions="52,250,*,300">
            
            <!-- Activity Bar (leftmost sidebar) -->
            <Border Grid.Column="0" Background="{StaticResource SidebarGradient}" Padding="2,8">
                <StackPanel Spacing="4">
                    <Button Classes="sidebar-button active" Name="ExplorerButton" ToolTip.Tip="Explorer (Ctrl+Shift+E)" Click="Explorer_Click">
                        <TextBlock Text="📁" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="sidebar-button" Name="SearchButton" ToolTip.Tip="Search (Ctrl+Shift+F)" Click="Search_Click">
                        <TextBlock Text="🔍" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="sidebar-button" Name="GitButton" ToolTip.Tip="Source Control (Ctrl+Shift+G)" Click="Git_Click">
                        <TextBlock Text="🔀" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="sidebar-button" Name="DebugButton" ToolTip.Tip="Run and Debug (Ctrl+Shift+D)" Click="Debug_Click">
                        <TextBlock Text="🐛" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="sidebar-button" Name="ExtensionsButton" ToolTip.Tip="Extensions (Ctrl+Shift+X)" Click="Extensions_Click">
                        <TextBlock Text="🧩" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    
                    <!-- Spacer -->
                    <Panel VerticalAlignment="Stretch"/>
                    
                    <!-- Bottom buttons -->
                    <Button Classes="sidebar-button" Name="AccountButton" ToolTip.Tip="Account" Click="Account_Click">
                        <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Classes="sidebar-button" Name="SettingsButton" ToolTip.Tip="Settings (Ctrl+,)" Click="Settings_Click">
                        <TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Side Panel (Explorer, Search, Git, etc.) -->
            <Border Grid.Column="1" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <!-- Explorer Panel (default) -->
                    <Grid RowDefinitions="Auto,*" Name="ExplorerPanel">
                        <!-- Panel Header -->
                        <Border Grid.Row="0" Padding="12,10" Background="#20000000">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="EXPLORER" FontSize="11" FontWeight="SemiBold" 
                                           Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center"
                                           LetterSpacing="1" Name="SidePanelHeaderText"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Name="ExplorerHeaderActions">
                                    <Button Classes="icon-button" Width="24" Height="24" ToolTip.Tip="New File" 
                                            Name="NewFileButton" Click="ExplorerNewFile_Click">
                                        <TextBlock Text="📄" FontSize="12"/>
                                    </Button>
                                    <Button Classes="icon-button" Width="24" Height="24" ToolTip.Tip="New Folder"
                                            Name="NewFolderButton" Click="ExplorerNewFolder_Click">
                                        <TextBlock Text="📁" FontSize="12"/>
                                    </Button>
                                <Button Classes="icon-button" Width="24" Height="24" ToolTip.Tip="Refresh"
                                        Name="RefreshTreeButton" Click="RefreshTree_Click">
                                    <TextBlock Text="🔄" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- File Tree -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Name="ExplorerScrollViewer">
                        <TreeView Name="FileTreeView" Margin="8,4"
                                  ItemsSource="{Binding FileTreeItems}"
                                  SelectionChanged="FileTreeView_SelectionChanged">
                            <TreeView.ContextMenu>
                                <ContextMenu Name="FileTreeContextMenu">
                                    <MenuItem Header="📄 Add New Item..." Click="AddNewItem_Click"/>
                                    <MenuItem Header="📁 Add New Folder" Click="AddNewFolder_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📦 Add New Project..." Click="AddNewProject_Click"/>
                                    <Separator/>
                                    <MenuItem Header="✏️ Rename" Click="RenameItem_Click"/>
                                    <MenuItem Header="🗑️ Delete" Click="DeleteItem_Click"/>
                                    <Separator/>
                                    <MenuItem Header="📋 Copy Path" Click="CopyPath_Click"/>
                                    <MenuItem Header="📂 Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <MenuItem Header="💻 Open in Terminal" Click="OpenInTerminal_Click"/>
                                    <Separator/>
                                    <MenuItem Header="🔄 Refresh" Click="RefreshTree_Click"/>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate x:DataType="models:FileTreeItem" ItemsSource="{Binding Children}">
                                    <Grid ColumnDefinitions="Auto,Auto,*" Height="24">
                                        <!-- Icon with proper color binding -->
                                        <Border Grid.Column="0" 
                                                Width="20" Height="20" 
                                                CornerRadius="4"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Background="{Binding IconBackgroundColor}">
                                            <TextBlock Text="{Binding Icon}" 
                                                       Foreground="{Binding IconColor}"
                                                       FontSize="12" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- File/Folder name with proper styling -->
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding DisplayName}" 
                                                   FontSize="13" 
                                                   Foreground="{Binding NameColor}"
                                                   FontWeight="{Binding FontWeight}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Project info for solution items -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding Description}" 
                                                   FontSize="10" 
                                                   Foreground="#FF6C6C80"
                                                   FontStyle="Italic"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   IsVisible="{Binding HasDescription}"/>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem" x:DataType="models:FileTreeItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                                <!-- Style for nested code-behind files -->
                                <Style Selector="TreeViewItem TreeViewItem">
                                    <Setter Property="Margin" Value="10,0,0,0"/>
                                </Style>
                            </TreeView.Styles>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
                
                <!-- Search Panel (hidden by default) -->
                <Grid RowDefinitions="Auto,Auto,*" Name="SearchPanel" IsVisible="False">
                    <Border Grid.Row="0" Padding="12,10" Background="#20000000">
                        <TextBlock Text="SEARCH" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center"
                                   LetterSpacing="1"/>
                    </Border>
                    <Border Grid.Row="1" Margin="8,8,8,0" Padding="8" Background="#20000000" CornerRadius="6">
                        <StackPanel Spacing="8">
                            <TextBox Name="SearchInputBox" Watermark="Search..." 
                                     Background="#FF1E1E2E" BorderBrush="{StaticResource AppBorderBrush}"
                                     Foreground="{StaticResource AppTextBrush}" CornerRadius="4" Padding="8,6"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Name="ReplaceInputBox" Watermark="Replace..." 
                                         Background="#FF1E1E2E" BorderBrush="{StaticResource AppBorderBrush}"
                                         Foreground="{StaticResource AppTextBrush}" CornerRadius="4" Padding="8,6"/>
                                <Button Grid.Column="1" Classes="icon-button" Margin="4,0,0,0" Width="28" Height="28"
                                        ToolTip.Tip="Replace All" Name="ReplaceAllButton">
                                    <TextBlock Text="↻" FontSize="14"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="2" Margin="8">
                        <StackPanel Name="SearchResultsPanel">
                            <TextBlock Text="Enter a search term above" FontSize="12" 
                                       Foreground="{StaticResource AppTextMutedBrush}" FontStyle="Italic"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                
                <!-- Git Panel (hidden by default) - placeholder container -->
                <Border Name="GitSidePanel" IsVisible="False">
                    <!-- GitPanelControl will be added programmatically -->
                </Border>
                
                <!-- Debug Panel (hidden by default) -->
                <Grid RowDefinitions="Auto,*" Name="DebugSidePanel" IsVisible="False">
                    <Border Grid.Row="0" Padding="12,10" Background="#20000000">
                        <TextBlock Text="RUN AND DEBUG" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center"
                                   LetterSpacing="1"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" Margin="8">
                        <StackPanel Spacing="12">
                            <Button Classes="primary-button" Content="▶ Start Debugging" 
                                    HorizontalAlignment="Stretch" Name="StartDebugButton" Click="StartDebug_Click"/>
                            <Expander Header="Variables" IsExpanded="True">
                                <TextBlock Text="No debugging session" FontSize="12" 
                                           Foreground="{StaticResource AppTextMutedBrush}" Margin="8"/>
                            </Expander>
                            <Expander Header="Watch">
                                <TextBlock Text="Add expressions to watch" FontSize="12" 
                                           Foreground="{StaticResource AppTextMutedBrush}" Margin="8"/>
                            </Expander>
                            <Expander Header="Call Stack">
                                <TextBlock Text="No call stack" FontSize="12" 
                                           Foreground="{StaticResource AppTextMutedBrush}" Margin="8"/>
                            </Expander>
                            <Expander Header="Breakpoints" IsExpanded="True">
                                <TextBlock Text="No breakpoints set" FontSize="12" 
                                           Foreground="{StaticResource AppTextMutedBrush}" Margin="8"/>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                
                <!-- Extensions Panel (hidden by default) -->
                <Grid RowDefinitions="Auto,Auto,*" Name="ExtensionsPanel" IsVisible="False">
                    <Border Grid.Row="0" Padding="12,10" Background="#20000000">
                        <TextBlock Text="EXTENSIONS" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center"
                                   LetterSpacing="1"/>
                    </Border>
                    <Border Grid.Row="1" Margin="8,8,8,0" Padding="8" Background="#20000000" CornerRadius="6">
                        <TextBox Watermark="Search extensions..." 
                                 Background="#FF1E1E2E" BorderBrush="{StaticResource AppBorderBrush}"
                                 Foreground="{StaticResource AppTextBrush}" CornerRadius="4" Padding="8,6"/>
                    </Border>
                    <ScrollViewer Grid.Row="2" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Extensions coming soon..." FontSize="12" 
                                       Foreground="{StaticResource AppTextMutedBrush}" FontStyle="Italic"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                </Grid>
            </Border>
            
            <!-- Main Editor Area -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto,200" Name="EditorGrid">
                <!-- Tab Bar -->
                <Border Grid.Row="0" Background="#20000000" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tabs}" Height="36">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:EditorTab">
                                    <Button Classes="tab-button" 
                                            Tag="{Binding}"
                                            Click="TabButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Language}" FontSize="10" 
                                                       Foreground="{StaticResource AccentGreenBrush}" 
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DisplayFileName}" VerticalAlignment="Center"/>
                                            <Button Width="16" Height="16" 
                                                    Background="Transparent" 
                                                    BorderThickness="0" 
                                                    Padding="0" 
                                                    Cursor="Hand"
                                                    Tag="{Binding}"
                                                    Click="CloseTabButton_Click">
                                                <TextBlock Text="✕" FontSize="10" Foreground="{StaticResource AppTextMutedBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                
                <!-- Monaco Editor Container (WebView) -->
                <Border Grid.Row="1" Background="#FF1E1E1E" Name="MonacoEditorContainer">
                    <!-- MonacoEditorControl will be added programmatically -->
                </Border>
                
                <!-- Resize grip for terminal -->
                <GridSplitter Grid.Row="2" Height="5" Classes="tool-splitter"
                              ResizeDirection="Rows" HorizontalAlignment="Stretch"/>
                
                <!-- Terminal / Output Panel (JetBrains Rider Style) -->
                <Border Grid.Row="3" Background="#FF252529" BorderBrush="#FF3C3F41" BorderThickness="0,1,0,0">
                    <Grid RowDefinitions="32,*">
                        <!-- Tool Window Header Bar (Rider-style) -->
                        <Border Grid.Row="0" Background="#FF3C3F41">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Left: Tabs -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Stretch">
                                    <!-- Problems Tab -->
                                    <Button Classes="tool-window-tab" Name="ProblemsTabButton" Click="ProblemsTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⚠" FontSize="12" Foreground="#FFF5A623"/>
                                            <TextBlock Text="Problems" FontSize="12"/>
                                            <Border Background="#50F38BA8" CornerRadius="8" Padding="5,1" IsVisible="{Binding HasProblems}">
                                                <TextBlock Text="{Binding ProblemsCount}" FontSize="10" Foreground="#FFF38BA8" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Button>
                                    
                                    <!-- Build Tab -->
                                    <Button Classes="tool-window-tab" Name="BuildTabButton" Click="BuildTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="🔨" FontSize="11"/>
                                            <TextBlock Text="Build" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <!-- Run Tab -->
                                    <Button Classes="tool-window-tab" Name="RunTabButton" Click="RunTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="▶" FontSize="10" Foreground="#FFA6E3A1"/>
                                            <TextBlock Text="Run" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <!-- Terminal Tab (Active by default) -->
                                    <Button Classes="tool-window-tab active" Name="TerminalTabButton" Click="TerminalTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⬛" FontSize="10"/>
                                            <TextBlock Text="Terminal" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <!-- Git Tab -->
                                    <Button Classes="tool-window-tab" Name="GitTabButton" Click="GitTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="🔀" FontSize="11"/>
                                            <TextBlock Text="Git" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <!-- Debug Tab -->
                                    <Button Classes="tool-window-tab" Name="DebugConsoleTabButton" Click="DebugConsoleTab_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="🐛" FontSize="11"/>
                                            <TextBlock Text="Debug" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                
                                <!-- Center: Empty space / Additional info -->
                                <Panel Grid.Column="1"/>
                                
                                <!-- Right: Tool Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="0,0,4,0" VerticalAlignment="Center">
                                    <!-- Terminal dropdown -->
                                    <Button Classes="tool-action-button" ToolTip.Tip="Terminal: PowerShell" Name="TerminalDropdown">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="PowerShell" FontSize="11" Foreground="{StaticResource AppTextMutedBrush}"/>
                                            <TextBlock Text="▾" FontSize="9" Foreground="{StaticResource AppTextMutedBrush}"/>
                                        </StackPanel>
                                    </Button>
                                    <Border Width="1" Height="16" Background="#FF505053" Margin="4,0"/>
                                    <Button Classes="tool-action-button" ToolTip.Tip="New Terminal (Ctrl+Shift+`)" Name="NewTerminalButton" Click="NewTerminal_Click">
                                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
                                    </Button>
                                    <Button Classes="tool-action-button" ToolTip.Tip="Split Terminal" Name="SplitTerminalButton">
                                        <TextBlock Text="⫿" FontSize="12"/>
                                    </Button>
                                    <Border Width="1" Height="16" Background="#FF505053" Margin="4,0"/>
                                    <Button Classes="tool-action-button" ToolTip.Tip="Clear All" Name="ClearTerminalButton" Click="ClearTerminal_Click">
                                        <TextBlock Text="🗑" FontSize="11"/>
                                    </Button>
                                    <Button Classes="tool-action-button" ToolTip.Tip="Scroll to End">
                                        <TextBlock Text="↓" FontSize="12"/>
                                    </Button>
                                    <Border Width="1" Height="16" Background="#FF505053" Margin="4,0"/>
                                    <Button Classes="tool-action-button" ToolTip.Tip="Minimize" Name="MinimizePanelButton" Click="MinimizePanel_Click">
                                        <TextBlock Text="▁" FontSize="10"/>
                                    </Button>
                                    <Button Classes="tool-action-button" ToolTip.Tip="Maximize" Name="MaximizePanelButton" Click="MaximizePanel_Click">
                                        <TextBlock Text="▢" FontSize="10"/>
                                    </Button>
                                    <Button Classes="tool-action-button" ToolTip.Tip="Hide (Esc)" Name="HidePanelButton" Click="HidePanel_Click">
                                        <TextBlock Text="✕" FontSize="10"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Terminal Content Area -->
                        <Grid Grid.Row="1">
                            <!-- Left side: Terminal sessions list (optional, collapsed by default) -->
                            <!-- Main Terminal Content -->
                            <Border Name="TerminalContainer" Background="#FF1E1E1E"/>
                            
                            <!-- Problems Panel (hidden by default) -->
                            <Border Name="ProblemsPanel" Background="#FF252529" IsVisible="False">
                                <Grid RowDefinitions="Auto,*">
                                    <Border Grid.Row="0" Background="#FF2D2D30" Padding="8,4">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="⛔" FontSize="11" Foreground="#FFF38BA8"/>
                                                    <TextBlock Text="{Binding ErrorsCount, StringFormat='{}{0} Errors'}" FontSize="11" Foreground="#FFF38BA8" Name="ProblemsErrorsText"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="⚠" FontSize="11" Foreground="#FFF5A623"/>
                                                    <TextBlock Text="{Binding WarningsCount, StringFormat='{}{0} Warnings'}" FontSize="11" Foreground="#FFF5A623" Name="ProblemsWarningsText"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="ℹ" FontSize="11" Foreground="#FF89B4FA"/>
                                                    <TextBlock Text="0 Messages" FontSize="11" Foreground="{StaticResource AppTextMutedBrush}" Name="ProblemsMessagesText"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                                <Button Classes="tool-action-button" ToolTip.Tip="Refresh Analysis" Name="RefreshAnalysisButton" Click="RefreshAnalysis_Click">
                                                    <TextBlock Text="🔄" FontSize="11"/>
                                                </Button>
                                                <Button Classes="tool-action-button" ToolTip.Tip="Clear Problems" Name="ClearProblemsButton" Click="ClearProblems_Click">
                                                    <TextBlock Text="🗑" FontSize="11"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ListBox Grid.Row="1" Name="ProblemsListBox" 
                                             ItemsSource="{Binding Problems}"
                                             Background="Transparent"
                                             SelectionChanged="ProblemsListBox_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DiagnosticItem">
                                                <Grid ColumnDefinitions="24,Auto,*,Auto" Margin="4,2" Background="Transparent">
                                                    <!-- Severity Icon -->
                                                    <TextBlock Grid.Column="0" Text="{Binding SeverityIcon}" FontSize="12" VerticalAlignment="Center"/>
                                                    <!-- Code -->
                                                    <Border Grid.Column="1" Background="#30808080" CornerRadius="3" Padding="4,1" Margin="4,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Code}" FontSize="10" Foreground="#FF89B4FA" FontFamily="Consolas"/>
                                                    </Border>
                                                    <!-- Message -->
                                                    <TextBlock Grid.Column="2" Text="{Binding Message}" FontSize="12" 
                                                               Foreground="{StaticResource AppTextBrush}" 
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="4,0"/>
                                                    <!-- Location -->
                                                    <TextBlock Grid.Column="3" Text="{Binding Location}" FontSize="11" 
                                                               Foreground="{StaticResource AppTextMutedBrush}" 
                                                               VerticalAlignment="Center"
                                                               FontFamily="Consolas"
                                                               Margin="8,0,4,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.Styles>
                                            <Style Selector="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="MinHeight" Value="24"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                            </Style>
                                            <Style Selector="ListBoxItem:pointerover">
                                                <Setter Property="Background" Value="#20FFFFFF"/>
                                            </Style>
                                            <Style Selector="ListBoxItem:selected">
                                                <Setter Property="Background" Value="#30FAB387"/>
                                            </Style>
                                        </ListBox.Styles>
                                    </ListBox>
                                    <!-- Empty state -->
                                    <TextBlock Grid.Row="1" Text="No problems detected. Press Analyze to check for issues." 
                                               FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" 
                                               Margin="16,12" FontStyle="Italic"
                                               IsVisible="{Binding !HasProblems}"
                                               Name="NoProblemsText"/>
                                </Grid>
                            </Border>
                            
                            <!-- Build Output Panel (hidden by default) -->
                            <Border Name="BuildPanel" Background="#FF1E1E1E" IsVisible="False">
                                <ScrollViewer Name="BuildOutputScrollViewer" 
                                              HorizontalScrollBarVisibility="Auto" 
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock Name="BuildOutputText" 
                                               Text="Build output will appear here..." 
                                               FontFamily="Consolas, Monaco, monospace" 
                                               FontSize="12"
                                               Foreground="{StaticResource AppTextBrush}" 
                                               Margin="12,8"
                                               TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                            
                            <!-- Run Output Panel (hidden by default) -->
                            <Border Name="RunPanel" Background="#FF1E1E1E" IsVisible="False">
                                <ScrollViewer>
                                    <TextBlock Name="RunOutputText" Text="Run output will appear here..." 
                                               FontFamily="Consolas, Monaco, monospace" FontSize="12"
                                               Foreground="{StaticResource AppTextMutedBrush}" Margin="12,8"/>
                                </ScrollViewer>
                            </Border>
                            
                            <!-- Git Panel (hidden by default) -->
                            <Border Name="GitPanel" Background="#FF252529" IsVisible="False">
                                <StackPanel Margin="12,8" Spacing="8">
                                    <TextBlock Text="Git Log" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}"/>
                                    <TextBlock Text="No repository opened" FontSize="12" Foreground="{StaticResource AppTextMutedBrush}" FontStyle="Italic"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Debug Panel (hidden by default) -->
                            <Border Name="DebugPanel" Background="#FF1E1E1E" IsVisible="False">
                                <ScrollViewer>
                                    <TextBlock Name="DebugOutputText" Text="Debug console ready..." 
                                               FontFamily="Consolas, Monaco, monospace" FontSize="12"
                                               Foreground="{StaticResource AppTextMutedBrush}" Margin="12,8"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Right Panel (AI Assistant / Properties) -->
            <Border Grid.Column="3" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1,0,0,0"
                    Name="AIPanelBorder">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Panel Header -->
                    <Border Grid.Row="0" Padding="12,10" Background="#20000000">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🤖" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="AI ASSISTANT" FontSize="11" FontWeight="SemiBold" 
                                           Foreground="{StaticResource AppTextMutedBrush}" VerticalAlignment="Center"
                                           LetterSpacing="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Button Classes="icon-button" Width="24" Height="24" ToolTip.Tip="New Chat">
                                    <TextBlock Text="➕" FontSize="12"/>
                                </Button>
                                <Button Classes="icon-button" Width="24" Height="24" ToolTip.Tip="Close Panel" 
                                        Name="CloseAIPanelButton" Click="CloseAIPanel_Click">
                                    <TextBlock Text="✕" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Chat messages -->
                    <ScrollViewer Grid.Row="1" Margin="12,8">
                        <StackPanel Spacing="12" Name="AIChatMessages">
                            <!-- AI Welcome message -->
                            <Border Background="#30FAB387" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Welcome to Insait Edit!" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}"/>
                                    <TextBlock Text="I'm your AI coding assistant. I can help you with:" 
                                               Foreground="{StaticResource AppTextMutedBrush}" TextWrapping="Wrap"/>
                                    <StackPanel Spacing="4" Margin="8,4,0,0">
                                        <TextBlock Text="• Writing and explaining code" Foreground="{StaticResource AppTextBrush}" FontSize="12"/>
                                        <TextBlock Text="• Debugging and fixing errors" Foreground="{StaticResource AppTextBrush}" FontSize="12"/>
                                        <TextBlock Text="• Code refactoring suggestions" Foreground="{StaticResource AppTextBrush}" FontSize="12"/>
                                        <TextBlock Text="• Documentation generation" Foreground="{StaticResource AppTextBrush}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Chat input -->
                    <Border Grid.Row="2" Padding="12" Background="#20000000">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                            <TextBox Name="AIChatInput" 
                                     Watermark="Ask me anything about your code..."
                                     Background="#FF2D2D3D"
                                     BorderBrush="{StaticResource AppBorderBrush}"
                                     Foreground="{StaticResource AppTextBrush}"
                                     CornerRadius="8"
                                     Padding="12,10"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"/>
                            <Button Grid.Column="1" Classes="icon-button" Margin="8,0,0,0" 
                                    Background="{StaticResource AccentOrangeBrush}"
                                    ToolTip.Tip="Send message" Name="SendAIButton" Click="SendAI_Click">
                                <TextBlock Text="➤" FontSize="16" Foreground="#FF1E1E2E"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- ROW 2: STATUS BAR (JetBrains Rider Style) -->
        <Border Grid.Row="2" Background="#FF3C3F41" BorderBrush="#FF505053" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: Branch info and status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <!-- Git Branch -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Git Branch">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="⎇" FontSize="11" Foreground="#FFA6E3A1"/>
                            <TextBlock Text="main" FontSize="11" Foreground="#FFB0B0B0" Name="GitBranchText"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Sync status -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Synchronize Changes">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="↓0" FontSize="10" Foreground="#FF89B4FA"/>
                            <TextBlock Text="↑0" FontSize="10" Foreground="#FFA6E3A1"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Errors/Warnings -->
                    <Button Classes="status-bar-button" ToolTip.Tip="View Problems" Name="StatusProblemsButton" Click="StatusProblems_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <TextBlock Text="⛔" FontSize="9" Foreground="#FFF38BA8"/>
                                <TextBlock Text="{Binding ErrorsCount}" FontSize="11" Foreground="#FFF38BA8" Name="StatusErrorsCount"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <TextBlock Text="⚠" FontSize="9" Foreground="#FFF5A623"/>
                                <TextBlock Text="{Binding WarningsCount}" FontSize="11" Foreground="#FFF5A623" Name="StatusWarningsCount"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Center: Status message -->
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="11" 
                           Foreground="#FF9399B2" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Name="StatusMessageText"/>
                
                <!-- Right: Editor info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <!-- Encoding -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Select Encoding">
                        <TextBlock Text="UTF-8" FontSize="11" Foreground="#FFB0B0B0"/>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Line Endings -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Select End of Line Sequence">
                        <TextBlock Text="CRLF" FontSize="11" Foreground="#FFB0B0B0" Name="LineEndingsText"/>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Language -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Select Language Mode">
                        <TextBlock Text="C#" FontSize="11" Foreground="#FFB0B0B0" Name="LanguageModeText"/>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Cursor Position -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Go to Line">
                        <TextBlock Text="Ln 1, Col 1" FontSize="11" Foreground="#FFB0B0B0" Name="CursorPositionText"/>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Spaces/Tabs -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Select Indentation">
                        <TextBlock Text="Spaces: 4" FontSize="11" Foreground="#FFB0B0B0"/>
                    </Button>
                    <Border Width="1" Height="14" Background="#FF505053" Margin="4,0"/>
                    <!-- Notifications -->
                    <Button Classes="status-bar-button" ToolTip.Tip="Notifications" Name="NotificationsButton">
                        <TextBlock Text="🔔" FontSize="11" Foreground="#FFB0B0B0"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
