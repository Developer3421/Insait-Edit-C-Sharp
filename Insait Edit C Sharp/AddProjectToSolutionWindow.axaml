<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DesignWidth="740" d:DesignHeight="620"
        x:Class="Insait_Edit_C_Sharp.AddProjectToSolutionWindow"
        Title="Add New Project"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="740"
        Height="620"
        CanResize="False"
        FontFamily="Segoe UI, Arial, Tahoma">

    <Window.Resources>
        <Color x:Key="BgPrimary">#FF1F1A24</Color>
        <Color x:Key="BgSecondary">#FF2A2230</Color>
        <Color x:Key="BgTertiary">#FF352840</Color>
        <Color x:Key="BorderColor">#FF3E3050</Color>
        <Color x:Key="TextPrimary">#FFF0E8F4</Color>
        <Color x:Key="TextSecondary">#FF9E90B0</Color>
        <Color x:Key="AccentOrange">#FFFFC09F</Color>
        <Color x:Key="AccentGreen">#FFA6E3A1</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.window-control">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="#20DCC4FF"/>
        </Style>
        <Style Selector="Button.window-control.close:pointerover">
            <Setter Property="Background" Value="#30DCC4FF"/>
        </Style>

        <Style Selector="Button.template-btn">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.template-btn:pointerover">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
        <Style Selector="Button.template-btn.selected">
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Background" Value="#FF3E3050"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>

        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-btn:pointerover">
            <Setter Property="Background" Value="#FFFFD4B8"/>
        </Style>

        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        
        <!-- Emoji icons style - preserve natural colors -->
        <Style Selector="Button.template-btn TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
        <Style Selector="StackPanel TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
    </Window.Styles>

    <Window.Background>
        <SolidColorBrush Color="{StaticResource BgPrimary}"/>
    </Window.Background>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="40,*,Auto">
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#FF2D2438">
                <Grid ColumnDefinitions="*,Auto">
                    <Panel Grid.Column="0" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="➕" FontSize="14"/>
                            <TextBlock Name="TitleBarText" Text="Add New Project to Solution" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentOrangeBrush}"/>
                        </StackPanel>
                    </Panel>
                    <Button Grid.Column="1" Classes="window-control close" Click="CloseButton_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="24">
                <StackPanel Spacing="20">
                    
                    <!-- Solution Info -->
                    <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock Name="SolutionLabel" Text="Solution:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Name="SolutionPathText" FontSize="12" Foreground="{StaticResource AccentGreenBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Template Selection -->
                    <StackPanel Spacing="8">
                        <TextBlock Name="TemplateLabel" Text="Project template" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        
                        <WrapPanel Orientation="Horizontal">
                            <Button Classes="template-btn selected" Name="ConsoleTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="console">
                                <StackPanel Width="120">
                                    <TextBlock Text="💻" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Console App" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Command-line app" FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="ClassLibTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="classlib">
                                <StackPanel Width="120">
                                    <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Class Library" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Reusable library" FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="AvaloniaTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="avalonia">
                                <StackPanel Width="120">
                                    <TextBlock Text="🖼️" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avalonia App" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Cross-platform UI" FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="WebApiTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="webapi">
                                <StackPanel Width="120">
                                    <TextBlock Text="🌐" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Web API" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="RESTful service" FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="XUnitTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="xunit">
                                <StackPanel Width="120">
                                    <TextBlock Text="🧪" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="xUnit Tests" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Unit test project" FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="WpfTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="wpf">
                                <StackPanel Width="120">
                                    <TextBlock Text="🪟" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="WPF App" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Windows desktop" FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="FSharpConsoleTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="fsharp-console">
                                <StackPanel Width="120">
                                    <TextBlock Text="🔷" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="F# Console" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="F# console app" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="FSharpEmptyTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="fsharp-empty">
                                <StackPanel Width="120">
                                    <TextBlock Text="🔹" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="F# Empty" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Minimal F# library" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="WinFormsTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="winforms">
                                <StackPanel Width="120">
                                    <TextBlock Text="🗔" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="WinForms" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Windows Forms app" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="CSharpEmptyTemplate" Margin="0,0,8,8"
                                    Click="Template_Click" Tag="csharp-empty">
                                <StackPanel Width="120">
                                    <TextBlock Text="📄" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="C# Empty" FontSize="12" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="Empty C# project" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Project Settings -->
                    <StackPanel Spacing="12">
                        <TextBlock Name="ProjectNameLabel" Text="Project name" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Name="ProjectNameBox" Text="NewProject" TextChanged="ProjectName_Changed"/>
                    </StackPanel>

                    <!-- Preview -->
                    <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock Name="CreatedAtLabel" Text="Project will be created at:" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Name="ProjectPathPreview" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" Padding="24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Button Grid.Column="1" Name="CancelButton" Classes="secondary-btn" Content="Cancel" 
                            Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Grid.Column="2" Name="CreateButton" Classes="primary-btn" Content="Add Project" 
                            Click="Create_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
