<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.App"
             xmlns:semi="https://irihi.tech/semi">

    <Application.Styles>
        <FluentTheme/>
        <!-- AvaloniaEdit Semi theme — styles only TextEditor parts,
             does NOT replace FluentTheme for the rest of the application -->
  

        <!-- Global style for emoji icons - ensures color emoji rendering -->
        <Style Selector="TextBlock.emoji">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Noto Color Emoji, Apple Color Emoji, Segoe UI Symbol"/>
        </Style>
    </Application.Styles>
</Application>