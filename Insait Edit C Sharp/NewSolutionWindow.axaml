<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="Insait_Edit_C_Sharp.NewSolutionWindow"
        Title="New Solution"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="600"
        Height="400"
        CanResize="False"
        FontFamily="Segoe UI, Arial, Tahoma">

    <Window.Resources>
        <Color x:Key="BgPrimary">#FF1F1A24</Color>
        <Color x:Key="BgSecondary">#FF2A2230</Color>
        <Color x:Key="BgTertiary">#FF352840</Color>
        <Color x:Key="BorderColor">#FF3E3050</Color>
        <Color x:Key="TextPrimary">#FFF0E8F4</Color>
        <Color x:Key="TextSecondary">#FF9E90B0</Color>
        <Color x:Key="AccentOrange">#FFFFC09F</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.window-control">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
        </Style>
        <Style Selector="Button.window-control.close:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="SelectionBrush" Value="#60FFC09F"/>
            <Setter Property="SelectionForegroundBrush" Value="#FF1F1A24"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>

        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-btn:pointerover">
            <Setter Property="Background" Value="#FFFFC09F"/>
        </Style>

        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        
        <!-- Emoji icons style - preserve natural colors -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
    </Window.Styles>

    <Window.Background>
        <SolidColorBrush Color="{StaticResource BgPrimary}"/>
    </Window.Background>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="40,*,Auto">
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#FF3C3C3C">
                <Grid ColumnDefinitions="*,Auto">
                    <Panel Grid.Column="0" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
                        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="📦" FontSize="14"/>
                            <TextBlock Name="TitleBarText" Text="New Solution" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentOrangeBrush}"/>
                        </StackPanel>
                    </Panel>
                    <Button Grid.Column="1" Classes="window-control close" Click="CloseButton_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="24">
                <StackPanel Spacing="20">
                    
                    <!-- Solution Name -->
                    <StackPanel Spacing="8">
                        <TextBlock Name="SolutionNameLabel" Text="Solution name" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Name="SolutionNameBox" Text="MySolution" TextChanged="SolutionName_Changed"/>
                    </StackPanel>

                    <!-- Location -->
                    <StackPanel Spacing="8">
                        <TextBlock Name="LocationLabel" Text="Location" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Name="LocationBox" Text="" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Name="BrowseButton" Classes="secondary-btn" Content="Browse..." 
                                    Click="BrowseLocation_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- Options -->
                    <StackPanel Spacing="8">
                        <CheckBox Name="CreateSolutionDir" IsChecked="True"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Name="CreateSolutionDirText" Text="Create solution directory"/>
                        </CheckBox>
                        <CheckBox Name="CreateGitRepo" IsChecked="True"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock Name="InitGitRepoText" Text="Initialize Git repository"/>
                        </CheckBox>
                    </StackPanel>

                    <!-- Solution Format -->
                    <StackPanel Spacing="8">
                        <TextBlock Name="SolutionFormatLabel" Text="Solution format" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton Name="SlnxFormat" GroupName="SolutionFormat" IsChecked="True"
                                         Foreground="{StaticResource TextPrimaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="📄 .slnx" FontWeight="SemiBold"/>
                                    <TextBlock Text="(Modern XML format)" 
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton Name="SlnFormat" GroupName="SolutionFormat"
                                         Foreground="{StaticResource TextPrimaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="📦 .sln" FontWeight="SemiBold"/>
                                    <TextBlock Text="(Legacy format)" 
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>

                    <!-- Preview -->
                    <Border Background="{StaticResource BgTertiaryBrush}" CornerRadius="6" Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock Name="CreatedAtLabel" Text="Solution will be created at:" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Name="SolutionPathPreview" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" Padding="24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Button Grid.Column="1" Name="CancelButton" Classes="secondary-btn" Content="Cancel" 
                            Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Grid.Column="2" Name="CreateButton" Classes="primary-btn" Content="Create" 
                            Click="Create_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
