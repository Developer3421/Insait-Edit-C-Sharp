<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.GeminiSettingsWindow"
        Title="Gemini API Settings"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="500" Height="290"
        CanResize="False" ShowInTaskbar="False"
        Background="#FF1F1A24">
    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF2A2230"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="SelectionBrush" Value="#60FFC09F"/>
            <Setter Property="SelectionForegroundBrush" Value="#FF1F1A24"/>
            <Setter Property="CaretBrush" Value="#FFF0E8F4"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FF2A2230"/>
        </Style>
        <Style Selector="Button.action-btn">
            <Setter Property="Background" Value="#FF7C3AED"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-btn:pointerover">
            <Setter Property="Background" Value="#FF8B5CF6"/>
        </Style>
        <Style Selector="Button.cancel-btn">
            <Setter Property="Background" Value="#FF3D3050"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.cancel-btn:pointerover">
            <Setter Property="Background" Value="#FF4E4060"/>
        </Style>
    </Window.Styles>
    <Border BorderBrush="#FF3E3050" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="36,*">
            <Border Grid.Row="0" Background="#FF2D2438" CornerRadius="8,8,0,0"
                    Name="TitleBar" PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="🤖" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                        <TextBlock Text="{DynamicResource Gemini.Settings.Title}" FontSize="13" FontWeight="SemiBold" Foreground="#FFF0E8F4" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Name="CloseButton" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0" Width="36" Height="36" Padding="0" Cursor="Hand">
                        <TextBlock Text="✕" Foreground="#FFF0E8F4" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="24,20,24,20" Spacing="14">
                <StackPanel Spacing="6">
                    <TextBlock Text="{DynamicResource Gemini.Settings.ApiKeyLabel}" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFC09F"/>
                    <TextBox x:Name="ApiKeyBox" PasswordChar="•" Watermark="Paste your Gemini API key here..."
                             FontFamily="Cascadia Code, Consolas, monospace" FontSize="13"/>
                    <TextBlock Text="{DynamicResource Gemini.Settings.ApiKeyHint}"
                               FontSize="11" Foreground="#FF9E90B0" TextWrapping="Wrap"/>
                </StackPanel>
                <CheckBox x:Name="ShowKeyCheck" Content="{DynamicResource Gemini.Settings.ShowKey}" Foreground="#FF9E90B0" FontSize="12"
                          Checked="ShowKeyCheck_Checked" Unchecked="ShowKeyCheck_Unchecked"/>
                <Grid ColumnDefinitions="*,12,*">
                    <Button Grid.Column="0" Classes="cancel-btn" Click="CancelButton_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                        <TextBlock Text="{DynamicResource Gemini.Settings.Cancel}" FontSize="13"/>
                    </Button>
                    <Button Grid.Column="2" Classes="action-btn" Click="SaveButton_Click"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                        <TextBlock Text="{DynamicResource Gemini.Settings.Save}" FontSize="13"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>

