<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.PublishWindow"
        Title="Publish Project"
        Width="700"
        Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        SystemDecorations="None"
        Background="#FF1F1A24">
    
    <Window.Styles>
        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-button:pointerover">
            <Setter Property="Background" Value="#FF4A3D58"/>
        </Style>
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="#FFFFC09F"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-button:pointerover">
            <Setter Property="Background" Value="#FFFFD4B8"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FF352840"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
        </Style>
        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
        </Style>
        
        <!-- Emoji icons style - preserve natural colors -->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
    </Window.Styles>

    <Border BorderBrush="#FF3E3050" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="36,*,Auto">
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#FF3C3C3C" CornerRadius="8,8,0,0" Name="TitleBar">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="12,0">
                        <TextBlock Text="📦" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="Publish Project" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#FFF0E8F4" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Background="Transparent" Foreground="#FF9E90B0"
                            BorderThickness="0" Width="36" Height="36" Name="CloseButton">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20" Spacing="20">
                    <!-- Project Selection -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Project" FontWeight="SemiBold" Foreground="#FFF0E8F4" FontSize="13"/>
                        <ComboBox Name="ProjectComboBox" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Deployment Mode -->
                    <Border Background="#FF2A2230" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Deployment Mode" FontWeight="SemiBold" Foreground="#FFFFC09F" FontSize="13"/>
                            <RadioButton Content="Framework-dependent (requires .NET runtime on target)" 
                                         Name="FrameworkDependentRadio" IsChecked="True" GroupName="DeploymentMode"/>
                            <RadioButton Content="Self-contained (includes .NET runtime)" 
                                         Name="SelfContainedRadio" GroupName="DeploymentMode"/>
                        </StackPanel>
                    </Border>

                    <!-- Target Runtime -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,8,0">
                            <TextBlock Text="Configuration" FontWeight="SemiBold" Foreground="#FFF0E8F4" FontSize="13"/>
                            <ComboBox Name="ConfigurationComboBox" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Release" IsSelected="True"/>
                                <ComboBoxItem Content="Debug"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6" Margin="8,0,0,0">
                            <TextBlock Text="Target Runtime" FontWeight="SemiBold" Foreground="#FFF0E8F4" FontSize="13"/>
                            <ComboBox Name="RuntimeComboBox" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <!-- Target Framework -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Target Framework" FontWeight="SemiBold" Foreground="#FFF0E8F4" FontSize="13"/>
                        <ComboBox Name="FrameworkComboBox" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Output Path -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Output Folder" FontWeight="SemiBold" Foreground="#FFF0E8F4" FontSize="13"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Name="OutputPathBox" Watermark="bin\publish"/>
                            <Button Grid.Column="1" Content="📁" Classes="action-button" Margin="8,0,0,0" Width="40" Name="BrowseOutputButton"/>
                        </Grid>
                    </StackPanel>

                    <!-- Application Icon -->
                    <Border Background="#FF2A2230" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Application Icon (.ico)" FontWeight="SemiBold" Foreground="#FFFFC09F" FontSize="13"/>
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Icon preview -->
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8"
                                        Background="#FF352840" BorderBrush="#FF3E3050" BorderThickness="1"
                                        Margin="0,0,12,0" Name="IconPreviewBorder">
                                    <Panel>
                                        <TextBlock Text="🖼️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Name="IconPlaceholder"/>
                                        <Image Name="IconPreviewImage" Width="40" Height="40" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="False"/>
                                    </Panel>
                                </Border>
                                <TextBox Grid.Column="1" Name="IconPathBox" Watermark="(none — uses default icon)"
                                         IsReadOnly="True" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button Content="📁" Classes="action-button" Margin="8,0,0,0" Width="40" 
                                            Name="BrowseIconButton" ToolTip.Tip="Browse for .ico file"/>
                                    <Button Content="✕" Classes="action-button" Margin="4,0,0,0" Width="32"
                                            Name="ClearIconButton" ToolTip.Tip="Clear icon" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Select an .ico file to embed as the application icon in the published executable"
                                       FontSize="11" Foreground="#FF9E90B0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- Publish Options -->
                    <Border Background="#FF2A2230" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12" x:CompileBindings="False">
                            <TextBlock Text="Publish Options" FontWeight="SemiBold" Foreground="#FFFFC09F" FontSize="13"/>
                            
                            <CheckBox Content="Produce single file" Name="SingleFileCheck" ToolTip.Tip="Bundles the application into a single executable"/>
                            
                            <CheckBox Content="Enable ReadyToRun compilation" Name="ReadyToRunCheck" 
                                      ToolTip.Tip="Pre-compiles assemblies to native code for faster startup"/>
                            
                            <CheckBox Content="Trim unused assemblies" Name="TrimCheck" 
                                      ToolTip.Tip="Removes unused code to reduce size (may affect reflection)"/>
                            
                            <CheckBox Content="Enable compression in single file" Name="CompressionCheck" 
                                      ToolTip.Tip="Compresses the single file to reduce size" IsEnabled="{Binding #SingleFileCheck.IsChecked, FallbackValue=False}"/>
                            
                            <CheckBox Content="Include native libraries for self-extract" Name="NativeLibrariesCheck"
                                      ToolTip.Tip="Bundles native libraries into the single file" IsEnabled="{Binding #SingleFileCheck.IsChecked, FallbackValue=False}"/>
                        </StackPanel>
                    </Border>

                    <!-- Publish Profiles -->
                    <Border Background="#FF2A2230" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Publish Profile (Optional)" FontWeight="SemiBold" Foreground="#FF89B4FA" FontSize="13"/>
                                <Button Grid.Column="1" Content="+ New Profile" Classes="action-button" FontSize="11" Name="NewProfileButton"/>
                            </Grid>
                            <ComboBox Name="PublishProfileComboBox" HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Use existing publish profiles from Properties/PublishProfiles folder" 
                                       FontSize="11" Foreground="#FF9E90B0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick Presets -->
                    <Border Background="#FF2A2230" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Quick Presets" FontWeight="SemiBold" Foreground="#FFA6E3A1" FontSize="13"/>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="🪟 Windows x64" Classes="action-button" Margin="0,0,8,8" Name="PresetWinX64Button"/>
                                <Button Content="🪟 Windows ARM64" Classes="action-button" Margin="0,0,8,8" Name="PresetWinArm64Button"/>
                                <Button Content="🐧 Linux x64" Classes="action-button" Margin="0,0,8,8" Name="PresetLinuxX64Button"/>
                                <Button Content="🍎 macOS x64" Classes="action-button" Margin="0,0,8,8" Name="PresetMacX64Button"/>
                                <Button Content="🍎 macOS ARM64" Classes="action-button" Margin="0,0,8,8" Name="PresetMacArm64Button"/>
                                <Button Content="📱 Portable" Classes="action-button" Margin="0,0,8,8" Name="PresetPortableButton"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FF2A2230" Padding="16,12">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Estimated output size will appear after publish" FontSize="11" 
                                   Foreground="#FF9E90B0" VerticalAlignment="Center" Name="EstimatedSizeText"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Content="Cancel" Classes="action-button" Name="CancelButton"/>
                        <Button Content="📦 Publish" Classes="primary-button" Name="PublishButton"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

