<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:Insait_Edit_C_Sharp.Models"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             x:Class="Insait_Edit_C_Sharp.Controls.GitPanelControl">
    
    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="GitBgBrush" Color="#FF2D2D3D"/>
        <SolidColorBrush x:Key="GitSurfaceBrush" Color="#FF252535"/>
        <SolidColorBrush x:Key="GitBorderBrush" Color="#FF3D3D4D"/>
        <SolidColorBrush x:Key="GitTextBrush" Color="#FFCDD6F4"/>
        <SolidColorBrush x:Key="GitTextMutedBrush" Color="#FF9399B2"/>
        <SolidColorBrush x:Key="GitAccentBrush" Color="#FFFAB387"/>
        <SolidColorBrush x:Key="GitGreenBrush" Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="GitRedBrush" Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="GitBlueBrush" Color="#FF89B4FA"/>
        <SolidColorBrush x:Key="GitYellowBrush" Color="#FFF9E2AF"/>
    </UserControl.Resources>
    
    <UserControl.Styles>
        <!-- Section Header Style -->
        <Style Selector="Expander.section">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style Selector="Expander.section > ToggleButton">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        
        <!-- Git Action Button Style -->
        <Style Selector="Button.git-action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource GitTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.git-action:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
        </Style>
        <Style Selector="Button.git-action:pressed">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        
        <!-- Git Primary Button Style -->
        <Style Selector="Button.git-primary">
            <Setter Property="Background" Value="{StaticResource GitAccentBrush}"/>
            <Setter Property="Foreground" Value="#FF1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.git-primary:pointerover">
            <Setter Property="Background" Value="#FFFFC09F"/>
        </Style>
        <Style Selector="Button.git-primary:pressed">
            <Setter Property="Background" Value="#FFE09070"/>
        </Style>
        <Style Selector="Button.git-primary:disabled">
            <Setter Property="Background" Value="#50FAB387"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        
        <!-- Git Secondary Button Style -->
        <Style Selector="Button.git-secondary">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource GitTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GitBorderBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.git-secondary:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        
        <!-- File Item Style -->
        <Style Selector="Border.file-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Border.file-item:pointerover">
            <Setter Property="Background" Value="#20FFFFFF"/>
        </Style>
    </UserControl.Styles>
    
    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Padding="12,10" Background="#20000000">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="SOURCE CONTROL" FontSize="11" FontWeight="SemiBold" 
                           Foreground="{StaticResource GitTextMutedBrush}" VerticalAlignment="Center"
                           LetterSpacing="1"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button Classes="git-action" ToolTip.Tip="Refresh" Name="RefreshButton" Click="Refresh_Click">
                        <TextBlock Text="🔄" FontSize="12"/>
                    </Button>
                    <Button Classes="git-action" ToolTip.Tip="More Actions" Name="MoreActionsButton" Click="MoreActions_Click">
                        <TextBlock Text="⋯" FontSize="14" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                
                <!-- No Repository State -->
                <StackPanel Name="NoRepositoryPanel" Spacing="12" Margin="4,20">
                    <TextBlock Text="🔀" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="No Git repository" FontSize="14" FontWeight="SemiBold" 
                               HorizontalAlignment="Center" Foreground="{StaticResource GitTextBrush}"/>
                    <TextBlock Text="Open a folder containing a Git repository to see source control information."
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{StaticResource GitTextMutedBrush}" Margin="8,0"/>
                    <Button Classes="git-primary" Content="Initialize Repository" 
                            HorizontalAlignment="Center" Margin="0,8"
                            Name="InitRepoButton" Click="InitRepo_Click"/>
                    <Button Classes="git-secondary" Content="Clone Repository..." 
                            HorizontalAlignment="Center"
                            Name="CloneRepoButton" Click="CloneRepo_Click"/>
                </StackPanel>
                
                <!-- Repository Content -->
                <StackPanel Name="RepositoryPanel" IsVisible="False" Spacing="8">
                    
                    <!-- Branch Selector -->
                    <Border Background="#20FFFFFF" CornerRadius="6" Padding="8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="⎇" FontSize="14" Foreground="{StaticResource GitGreenBrush}" 
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                    HorizontalContentAlignment="Left" Name="BranchButton" Click="Branch_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="main" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{StaticResource GitTextBrush}" Name="CurrentBranchText"/>
                                    <TextBlock Text="▾" FontSize="10" Foreground="{StaticResource GitTextMutedBrush}" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                <Button Classes="git-action" ToolTip.Tip="Fetch" Name="FetchButton" Click="Fetch_Click">
                                    <TextBlock Text="⬇" FontSize="12"/>
                                </Button>
                                <Button Classes="git-action" ToolTip.Tip="Pull" Name="PullButton" Click="Pull_Click">
                                    <TextBlock Text="⤵" FontSize="14"/>
                                </Button>
                                <Button Classes="git-action" ToolTip.Tip="Push" Name="PushButton" Click="Push_Click">
                                    <TextBlock Text="⤴" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <!-- Sync Status -->
                    <Border Name="SyncStatusBorder" IsVisible="False" Background="#20FFFFFF" CornerRadius="4" Padding="8,4" Margin="0,4">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="↓" FontSize="12" Foreground="{StaticResource GitBlueBrush}"/>
                                <TextBlock Text="0" FontSize="12" Foreground="{StaticResource GitBlueBrush}" Name="BehindCountText"/>
                            </StackPanel>
                            <TextBlock Text="•" Foreground="{StaticResource GitTextMutedBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="↑" FontSize="12" Foreground="{StaticResource GitGreenBrush}"/>
                                <TextBlock Text="0" FontSize="12" Foreground="{StaticResource GitGreenBrush}" Name="AheadCountText"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- Commit Section -->
                    <Border Background="#20000000" CornerRadius="6" Padding="8" Margin="0,8,0,0">
                        <StackPanel Spacing="8">
                            <TextBox Name="CommitMessageBox" 
                                     Watermark="Commit message (press Ctrl+Enter to commit)"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="60"
                                     MaxHeight="120"
                                     Background="#FF1E1E2E"
                                     BorderBrush="{StaticResource GitBorderBrush}"
                                     Foreground="{StaticResource GitTextBrush}"
                                     FontSize="12"
                                     CornerRadius="4"
                                     Padding="8"/>
                            
                            <Grid ColumnDefinitions="*,Auto">
                                <Button Grid.Column="0" Classes="git-primary" Content="✓ Commit" 
                                        Name="CommitButton" Click="Commit_Click"
                                        IsEnabled="False"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                    <Button Classes="git-action" ToolTip.Tip="Commit and Push" Name="CommitPushButton" Click="CommitPush_Click">
                                        <TextBlock Text="⤴" FontSize="14"/>
                                    </Button>
                                    <Button Classes="git-action" ToolTip.Tip="Amend Previous Commit" Name="AmendButton" Click="Amend_Click">
                                        <TextBlock Text="✎" FontSize="12"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- Staged Changes Section -->
                    <Border Margin="0,8,0,0">
                        <Expander Name="StagedChangesExpander" IsExpanded="True">
                            <Expander.Header>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Staged Changes" FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource GitTextBrush}"/>
                                        <Border Background="#30A6E3A1" CornerRadius="8" Padding="6,2">
                                            <TextBlock Text="0" FontSize="10" Foreground="{StaticResource GitGreenBrush}" 
                                                       FontWeight="SemiBold" Name="StagedCountText"/>
                                        </Border>
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="git-action" ToolTip.Tip="Unstage All" 
                                            Name="UnstageAllButton" Click="UnstageAll_Click" Width="24" Height="24">
                                        <TextBlock Text="−" FontSize="16" FontWeight="Bold"/>
                                    </Button>
                                </Grid>
                            </Expander.Header>
                            <ItemsControl Name="StagedChangesList" Margin="0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:GitFileChange">
                                        <Border Classes="file-item" PointerPressed="StagedFile_PointerPressed">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Unstage" Click="UnstageFile_Click"/>
                                                    <MenuItem Header="View Changes" Click="ViewChanges_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4" 
                                                        Background="#20A6E3A1" 
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{Binding StatusColor}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="12" 
                                                           Foreground="{StaticResource GitTextBrush}" 
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Directory}" FontSize="10" 
                                                           Foreground="{StaticResource GitTextMutedBrush}" 
                                                           VerticalAlignment="Center" Margin="8,0" 
                                                           TextTrimming="CharacterEllipsis" MaxWidth="80"/>
                                                <Button Grid.Column="3" Classes="git-action" Width="22" Height="22"
                                                        ToolTip.Tip="Unstage" Tag="{Binding}"
                                                        Click="UnstageFileButton_Click">
                                                    <TextBlock Text="−" FontSize="14" FontWeight="Bold"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </Border>
                    
                    <!-- Changes Section (Unstaged) -->
                    <Border Margin="0,4,0,0">
                        <Expander Name="ChangesExpander" IsExpanded="True">
                            <Expander.Header>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Changes" FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource GitTextBrush}"/>
                                        <Border Background="#30FAB387" CornerRadius="8" Padding="6,2">
                                            <TextBlock Text="0" FontSize="10" Foreground="{StaticResource GitAccentBrush}" 
                                                       FontWeight="SemiBold" Name="ChangesCountText"/>
                                        </Border>
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="git-action" ToolTip.Tip="Discard All Changes" 
                                            Name="DiscardAllButton" Click="DiscardAll_Click" Width="24" Height="24">
                                        <TextBlock Text="↺" FontSize="14"/>
                                    </Button>
                                    <Button Grid.Column="2" Classes="git-action" ToolTip.Tip="Stage All" 
                                            Name="StageAllButton" Click="StageAll_Click" Width="24" Height="24">
                                        <TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
                                    </Button>
                                </Grid>
                            </Expander.Header>
                            <ItemsControl Name="ChangesList" Margin="0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:GitFileChange">
                                        <Border Classes="file-item" PointerPressed="UnstagedFile_PointerPressed">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Stage" Click="StageFile_Click"/>
                                                    <MenuItem Header="Discard Changes" Click="DiscardFile_Click"/>
                                                    <Separator/>
                                                    <MenuItem Header="View Changes" Click="ViewChanges_Click"/>
                                                    <MenuItem Header="Open File" Click="OpenFile_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                                <Border Grid.Column="0" Width="20" Height="20" CornerRadius="4" 
                                                        Background="#209399B2" 
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="11" FontWeight="Bold"
                                                               Foreground="{Binding StatusColor}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding FileName}" FontSize="12" 
                                                           Foreground="{StaticResource GitTextBrush}" 
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Directory}" FontSize="10" 
                                                           Foreground="{StaticResource GitTextMutedBrush}" 
                                                           VerticalAlignment="Center" Margin="8,0" 
                                                           TextTrimming="CharacterEllipsis" MaxWidth="60"/>
                                                <Button Grid.Column="3" Classes="git-action" Width="22" Height="22"
                                                        ToolTip.Tip="Discard Changes" Tag="{Binding}"
                                                        Click="DiscardFileButton_Click">
                                                    <TextBlock Text="↺" FontSize="12"/>
                                                </Button>
                                                <Button Grid.Column="4" Classes="git-action" Width="22" Height="22"
                                                        ToolTip.Tip="Stage" Tag="{Binding}"
                                                        Click="StageFileButton_Click">
                                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </Border>
                    
                    <!-- Stashes Section -->
                    <Border Margin="0,8,0,0">
                        <Expander Name="StashesExpander" IsExpanded="False">
                            <Expander.Header>
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Stashes" FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{StaticResource GitTextBrush}"/>
                                        <Border Background="#30CBA6F7" CornerRadius="8" Padding="6,2" Name="StashCountBorder" IsVisible="False">
                                            <TextBlock Text="0" FontSize="10" Foreground="#FFCBA6F7" 
                                                       FontWeight="SemiBold" Name="StashCountText"/>
                                        </Border>
                                    </StackPanel>
                                    <Button Grid.Column="1" Classes="git-action" ToolTip.Tip="Stash Changes" 
                                            Name="StashButton" Click="Stash_Click" Width="24" Height="24">
                                        <TextBlock Text="📦" FontSize="11"/>
                                    </Button>
                                </Grid>
                            </Expander.Header>
                            <StackPanel>
                                <ItemsControl Name="StashesList" Margin="0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitStash">
                                            <Border Classes="file-item">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Apply Stash" Click="ApplyStash_Click"/>
                                                        <MenuItem Header="Pop Stash" Click="PopStash_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="Drop Stash" Click="DropStash_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <TextBlock Grid.Column="0" Text="📦" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Message}" FontSize="12" 
                                                                   Foreground="{StaticResource GitTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Branch}" FontSize="10" 
                                                                   Foreground="{StaticResource GitTextMutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2">
                                                        <Button Classes="git-action" Width="22" Height="22" ToolTip.Tip="Apply" Tag="{Binding}"
                                                                Click="ApplyStashButton_Click">
                                                            <TextBlock Text="↩" FontSize="12"/>
                                                        </Button>
                                                        <Button Classes="git-action" Width="22" Height="22" ToolTip.Tip="Drop" Tag="{Binding}"
                                                                Click="DropStashButton_Click">
                                                            <TextBlock Text="🗑" FontSize="10"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Name="NoStashesPanel" IsVisible="True" Margin="8">
                                    <TextBlock Text="No stashes" FontSize="11" Foreground="{StaticResource GitTextMutedBrush}" 
                                               FontStyle="Italic"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </Border>
                    
                    <!-- Recent Commits Section -->
                    <Border Margin="0,8,0,0">
                        <Expander Name="CommitsExpander" IsExpanded="False">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Recent Commits" FontSize="12" FontWeight="SemiBold" 
                                               Foreground="{StaticResource GitTextBrush}"/>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel>
                                <ItemsControl Name="CommitsList" Margin="0,4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:GitCommit">
                                            <Border Classes="file-item" Padding="8,6">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" 
                                                            Background="#30FAB387" Margin="0,0,10,0">
                                                        <TextBlock Text="{Binding AuthorInitials}" FontSize="10" FontWeight="Bold"
                                                                   Foreground="{StaticResource GitAccentBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Message}" FontSize="12" 
                                                                   Foreground="{StaticResource GitTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding ShortHash}" FontSize="10" 
                                                                       Foreground="{StaticResource GitBlueBrush}"
                                                                       FontFamily="Consolas"/>
                                                            <TextBlock Text="{Binding RelativeDate}" FontSize="10" 
                                                                       Foreground="{StaticResource GitTextMutedBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Classes="git-secondary" Content="View Full History" 
                                        HorizontalAlignment="Stretch" Margin="4"
                                        Name="ViewHistoryButton" Click="ViewHistory_Click"/>
                            </StackPanel>
                        </Expander>
                    </Border>
                    
                </StackPanel>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#80000000" Name="LoadingOverlay" IsVisible="False">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <TextBlock Text="⏳" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading..." FontSize="14" Foreground="{StaticResource GitTextBrush}" Name="LoadingText"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

