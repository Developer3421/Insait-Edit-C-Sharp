<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.Controls.RoslynQuickFixWindow"
        Title="Quick Fix"
        SystemDecorations="None"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        TransparencyLevelHint="Transparent">

    <Window.Styles>
        <!-- ListBox item styles -->
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20DCC4FF"/>
        </Style>
    </Window.Styles>

    <Border Background="#FF1A1525"
            BorderBrush="#FF7C3AED"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#CC3E1060" BlurRadius="20" OffsetX="0" OffsetY="6" Opacity="0.8"/>
        </Border.Effect>

        <Grid RowDefinitions="Auto,*,Auto,Auto">
            <!-- Header -->
            <Border Grid.Row="0" Padding="10,5" Background="#18DCC4FF" CornerRadius="6,6,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="💡" FontSize="11"/>
                    <TextBlock x:Name="HeaderText" Text="{DynamicResource QuickFix.Header}"
                               FontSize="10" FontWeight="SemiBold" Foreground="#FF9E90B0"/>
                </StackPanel>
            </Border>

            <!-- Fix items list -->
            <ListBox Grid.Row="1" x:Name="FixList"
                     Background="Transparent"
                     BorderThickness="0"
                     MinWidth="340" MaxWidth="560"
                     MaxHeight="200"
                     Padding="2,2"
                     Focusable="False"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <!-- Description/explanation panel -->
            <Border Grid.Row="2" x:Name="DescriptionPanel"
                    Background="#12DCC4FF"
                    Padding="10,6"
                    IsVisible="False"
                    BorderBrush="#FF3E3050"
                    BorderThickness="0,1,0,0">
                <StackPanel Spacing="3" MaxWidth="500">
                    <TextBlock x:Name="DescTitle" Text=""
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#FFDCC4FF"
                               FontFamily="Cascadia Code, Consolas, monospace"/>
                    <TextBlock x:Name="DescDetail" Text=""
                               FontSize="10" Foreground="#FFB0A0C0"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="3" Padding="10,4" Background="#10DCC4FF" CornerRadius="0,0,6,6">
                <TextBlock Text="{DynamicResource QuickFix.Footer}"
                           FontSize="9" Foreground="#60DCC4FF"/>
            </Border>
        </Grid>
    </Border>
</Window>

