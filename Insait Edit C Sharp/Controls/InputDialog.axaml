<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.Controls.InputDialog"
        Title="Input"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="420"
        Height="170"
        CanResize="False"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Arial, Tahoma"
        Background="Transparent">

    <Window.Styles>
        <!-- TextBox -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF2A2230"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#FFF0E8F4"/>
            <Setter Property="SelectionBrush" Value="#60FFC09F"/>
            <Setter Property="SelectionForegroundBrush" Value="#FF1F1A24"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FF2A2230"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#FFFFC09F"/>
        </Style>
        <!-- Primary button (OK) -->
        <Style Selector="Button.ok-btn">
            <Setter Property="Background" Value="#FFFFC09F"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ok-btn:pointerover">
            <Setter Property="Background" Value="#FFFFD4B8"/>
        </Style>
        <Style Selector="Button.ok-btn:disabled">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="Foreground" Value="#FF6A5880"/>
        </Style>
        <!-- Secondary button (Cancel) -->
        <Style Selector="Button.cancel-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF9E90B0"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.cancel-btn:pointerover">
            <Setter Property="Background" Value="#FF2A2230"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
        </Style>
    </Window.Styles>

    <Border Background="#FF1F1A24"
            BorderBrush="#FF7C3AED"
            BorderThickness="1"
            CornerRadius="10"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#CC3E1060" BlurRadius="24" OffsetX="0" OffsetY="8" Opacity="0.8"/>
        </Border.Effect>

        <Grid RowDefinitions="Auto,*,Auto">
            <!-- Title bar -->
            <Border Grid.Row="0" Background="#18DCC4FF" Padding="14,8" CornerRadius="10,10,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="TitleIcon" Text="✏️" FontSize="14"
                                   FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TitleText" Text="Rename"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FFF0E8F4" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="CloseTitleBtn"
                            Content="✕" Width="28" Height="28"
                            Background="Transparent" Foreground="#FF9E90B0"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="16,14,16,10" Spacing="8">
                <TextBlock x:Name="PromptText" Text="Enter new name:"
                           FontSize="12" Foreground="#FF9E90B0"/>
                <TextBox x:Name="InputBox"/>
            </StackPanel>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Padding="16,8" Background="#10DCC4FF" CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <Button x:Name="CancelBtn" Classes="cancel-btn" Content="Cancel"/>
                    <Button x:Name="OkBtn" Classes="ok-btn" Content="OK"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

