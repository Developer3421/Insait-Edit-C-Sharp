<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.Controls.ProjectProps.BuildPage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="28,16,28,28">
        <StackPanel Spacing="0" MaxWidth="720">

            <TextBlock Text="{DynamicResource ProjectProps.Build.Header}" Classes="section-header" Margin="0,4,0,10"/>

            <TextBlock Text="{DynamicResource ProjectProps.Build.Configuration}" Classes="prop-label"/>
            <ComboBox Name="ConfigurationCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="Debug"/>
                <ComboBoxItem Content="Release"/>
            </ComboBox>

            <TextBlock Text="{DynamicResource ProjectProps.Build.PlatformTarget}" Classes="prop-label"/>
            <ComboBox Name="PlatformCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="Any CPU"/>
                <ComboBoxItem Content="x64"/>
                <ComboBoxItem Content="x86"/>
                <ComboBoxItem Content="ARM64"/>
            </ComboBox>

            <TextBlock Text="{DynamicResource ProjectProps.Build.CompilerHeader}" Classes="section-header"/>

            <CheckBox Name="OptimizeCheck"         Content="{DynamicResource ProjectProps.Build.Optimize}"          Margin="0,4,0,10"/>
            <CheckBox Name="WarningsAsErrorsCheck" Content="{DynamicResource ProjectProps.Build.WarningsAsErrors}"   Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Build.WarningLevel}" Classes="prop-label"/>
            <ComboBox Name="WarningLevelCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="0 — No warnings" Tag="0"/>
                <ComboBoxItem Content="1"               Tag="1"/>
                <ComboBoxItem Content="2"               Tag="2"/>
                <ComboBoxItem Content="3"               Tag="3"/>
                <ComboBoxItem Content="4 (default)"     Tag="4"/>
                <ComboBoxItem Content="5"               Tag="5"/>
            </ComboBox>

            <TextBlock Text="{DynamicResource ProjectProps.Build.SuppressWarnings}" Classes="prop-label"/>
            <TextBox Name="NoWarnBox" Watermark="e.g. CS1591;CS0618" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Build.OutputHeader}" Classes="section-header"/>

            <TextBlock Text="{DynamicResource ProjectProps.Build.OutputPath}" Classes="prop-label"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBox Name="OutputPathBox" Grid.Column="0" Watermark="bin\$(Configuration)\"/>
                <Button Grid.Column="1" Name="BrowseOutputButton"
                        Content="…" Width="38" Classes="small-btn" Margin="6,0,0,0"
                        ToolTip.Tip="{DynamicResource Common.Browse}"/>
            </Grid>

            <TextBlock Text="{DynamicResource ProjectProps.Build.IntermediateOutput}" Classes="prop-label"/>
            <TextBox Name="IntermediateOutputPathBox" Watermark="obj\" Margin="0,0,0,12"/>

            <CheckBox Name="GenerateDocXmlCheck" Content="{DynamicResource ProjectProps.Build.GenerateDocXml}" Margin="0,4,0,10"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
