<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.Controls.ProjectProps.PackagePage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="28,16,28,28">
        <StackPanel Spacing="0" MaxWidth="720">

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Header}" Classes="section-header" Margin="0,4,0,10"/>

            <CheckBox Name="GeneratePackageCheck"
                      Content="{DynamicResource ProjectProps.Pkg.GenerateOnBuild}"
                      Margin="0,0,0,16"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.PackageId}" Classes="prop-label"/>
            <TextBox Name="PackageIdBox" Watermark="e.g. MyCompany.MyLib" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Version}" Classes="prop-label"/>
            <TextBox Name="PackageVersionBox" Watermark="1.0.0" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Authors}" Classes="prop-label"/>
            <TextBox Name="AuthorsBox" Watermark="{DynamicResource ProjectProps.Pkg.WatermarkAuthors}" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Company}" Classes="prop-label"/>
            <TextBox Name="CompanyBox" Watermark="{DynamicResource ProjectProps.Pkg.WatermarkCompany}" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Product}" Classes="prop-label"/>
            <TextBox Name="ProductBox" Watermark="{DynamicResource ProjectProps.Pkg.WatermarkProduct}" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Description}" Classes="prop-label"/>
            <TextBox Name="PackageDescriptionBox"
                     Watermark="{DynamicResource ProjectProps.Pkg.WatermarkDescription}"
                     Height="76" AcceptsReturn="True" TextWrapping="Wrap"
                     Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.LinksHeader}" Classes="section-header"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.RepositoryUrl}" Classes="prop-label"/>
            <TextBox Name="RepositoryUrlBox" Watermark="https://github.com/…" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.LicenseExpression}" Classes="prop-label"/>
            <TextBox Name="LicenseExpressionBox" Watermark="MIT" Margin="0,0,0,12"/>

            <TextBlock Text="{DynamicResource ProjectProps.Pkg.Tags}" Classes="prop-label"/>
            <TextBox Name="PackageTagsBox" Watermark="tag1;tag2" Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
