<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.Controls.ProjectProps.PackagePage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="28,16,28,28">
        <StackPanel Spacing="0" MaxWidth="720">

            <TextBlock Text="PACKAGE / NUGET" Classes="section-header" Margin="0,4,0,10"/>

            <CheckBox Name="GeneratePackageCheck"
                      Content="Generate NuGet package on build"
                      Margin="0,0,0,16"/>

            <TextBlock Text="Package ID" Classes="prop-label"/>
            <TextBox Name="PackageIdBox" Watermark="e.g. MyCompany.MyLib" Margin="0,0,0,12"/>

            <TextBlock Text="Version" Classes="prop-label"/>
            <TextBox Name="PackageVersionBox" Watermark="1.0.0" Margin="0,0,0,12"/>

            <TextBlock Text="Authors" Classes="prop-label"/>
            <TextBox Name="AuthorsBox" Watermark="Author name" Margin="0,0,0,12"/>

            <TextBlock Text="Company" Classes="prop-label"/>
            <TextBox Name="CompanyBox" Watermark="My Company" Margin="0,0,0,12"/>

            <TextBlock Text="Product" Classes="prop-label"/>
            <TextBox Name="ProductBox" Watermark="My Product" Margin="0,0,0,12"/>

            <TextBlock Text="Description" Classes="prop-label"/>
            <TextBox Name="PackageDescriptionBox"
                     Watermark="Short description"
                     Height="76" AcceptsReturn="True" TextWrapping="Wrap"
                     Margin="0,0,0,12"/>

            <TextBlock Text="LINKS &amp; METADATA" Classes="section-header"/>

            <TextBlock Text="Repository URL" Classes="prop-label"/>
            <TextBox Name="RepositoryUrlBox" Watermark="https://github.com/…" Margin="0,0,0,12"/>

            <TextBlock Text="License expression (SPDX)" Classes="prop-label"/>
            <TextBox Name="LicenseExpressionBox" Watermark="MIT" Margin="0,0,0,12"/>

            <TextBlock Text="Tags (semicolon-separated)" Classes="prop-label"/>
            <TextBox Name="PackageTagsBox" Watermark="tag1;tag2" Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
