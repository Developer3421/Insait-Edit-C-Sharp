<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.Controls.ProjectProps.DebugPage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="28,16,28,28">
        <StackPanel Spacing="0" MaxWidth="720">

            <TextBlock Text="LAUNCH" Classes="section-header" Margin="0,4,0,10"/>

            <TextBlock Text="Launch profile" Classes="prop-label"/>
            <ComboBox Name="DebugLaunchProfileCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="Project"/>
                <ComboBoxItem Content="IIS Express"/>
            </ComboBox>

            <TextBlock Text="Application arguments" Classes="prop-label"/>
            <TextBox Name="DebugArgsBox" Watermark="Command line arguments" Margin="0,0,0,12"/>

            <TextBlock Text="Working directory" Classes="prop-label"/>
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                <TextBox Name="DebugWorkingDirBox" Grid.Column="0" Watermark="Project directory"/>
                <Button Grid.Column="1" Name="BrowseDebugDirButton"
                        Content="…" Width="38" Classes="small-btn"
                        Margin="6,0,0,0" ToolTip.Tip="Browse folder"/>
            </Grid>

            <CheckBox Name="EnableNativeDebugCheck"
                      Content="Enable native code debugging"
                      Margin="0,4,0,10"/>
            <CheckBox Name="EnableSqlDebugCheck"
                      Content="Enable SQL Server debugging"
                      Margin="0,0,0,10"/>

            <TextBlock Text="ENVIRONMENT VARIABLES" Classes="section-header"/>
            <TextBlock Text="Variables passed to the debug process:"
                       Classes="info-text" Margin="0,0,0,10"/>

            <Border Background="#FF1C1530" BorderBrush="#FF3A2E52" BorderThickness="1"
                    CornerRadius="8" ClipToBounds="True" Margin="0,0,0,12">
                <Grid RowDefinitions="Auto,Auto">
                    <!-- Header row -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,*,40"
                          Background="#FF17112A">
                        <TextBlock Grid.Column="0" Text="Name"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#FF9080A8" Margin="12,8"/>
                        <TextBlock Grid.Column="1" Text="Value"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#FF9080A8" Margin="12,8"/>
                        <Button Grid.Column="2" Name="AddEnvVarButton"
                                Content="+" Width="36" Height="32"
                                Classes="small-btn"
                                Margin="2" Padding="0"
                                ToolTip.Tip="Add environment variable"/>
                    </Grid>
                    <!-- Rows -->
                    <ItemsControl Grid.Row="1" Name="EnvVarsList" Margin="0,4"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
