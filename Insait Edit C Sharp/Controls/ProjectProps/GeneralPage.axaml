<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.Controls.ProjectProps.GeneralPage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="28,16,28,28">
        <StackPanel Spacing="0" MaxWidth="720">

            <!-- Application Icon -->
            <TextBlock Text="APPLICATION ICON" Classes="section-header" Margin="0,4,0,10"/>
            <Border Background="#FF1C1530" BorderBrush="#FF3A2E52" BorderThickness="1"
                    CornerRadius="8" Padding="16,14" Margin="0,0,0,4">
                <Grid ColumnDefinitions="88,*">
                    <Border Grid.Column="0" Width="80" Height="80"
                            Background="#FF14102A" CornerRadius="10"
                            BorderBrush="#FF3A2E52" BorderThickness="1"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Panel>
                            <TextBlock Name="AppIconPlaceholder" Text="🖼" FontSize="30"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Image Name="AppIconPreview" Width="64" Height="64" IsVisible="False"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Stretch="Uniform"/>
                        </Panel>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Application icon file (.ico)" Classes="prop-label" Margin="0"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox Name="AppIconPathBox" Grid.Column="0" Watermark="Path to .ico file…"/>
                            <Button Grid.Column="1" Name="BrowseIconButton"
                                    Content="Browse…" Classes="small-btn"
                                    Margin="6,0,0,0" ToolTip.Tip="Select .ico file"/>
                            <Button Grid.Column="2" Name="ClearIconButton"
                                    Content="✕" Width="34" Classes="small-btn"
                                    Margin="4,0,0,0" ToolTip.Tip="Clear icon"/>
                        </Grid>
                        <TextBlock Text="The .ico file is embedded as the application icon in the executable."
                                   Classes="info-text"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Assembly -->
            <TextBlock Text="ASSEMBLY" Classes="section-header"/>
            <TextBlock Text="Assembly name" Classes="prop-label"/>
            <TextBox Name="AssemblyNameBox" Watermark="e.g. MyApp" Margin="0,0,0,12"/>

            <TextBlock Text="Default namespace" Classes="prop-label"/>
            <TextBox Name="DefaultNamespaceBox" Watermark="e.g. MyApp" Margin="0,0,0,12"/>

            <TextBlock Text="Target framework" Classes="prop-label"/>
            <ComboBox Name="TargetFrameworkCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="net10.0"/>
                <ComboBoxItem Content="net9.0"/>
                <ComboBoxItem Content="net8.0"/>
                <ComboBoxItem Content="net7.0"/>
                <ComboBoxItem Content="net6.0"/>
                <ComboBoxItem Content="net5.0"/>
                <ComboBoxItem Content="netcoreapp3.1"/>
                <ComboBoxItem Content="netstandard2.1"/>
                <ComboBoxItem Content="netstandard2.0"/>
                <ComboBoxItem Content="net48"/>
                <ComboBoxItem Content="net472"/>
                <ComboBoxItem Content="net462"/>
            </ComboBox>

            <TextBlock Text="Output type" Classes="prop-label"/>
            <ComboBox Name="OutputTypeCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="Console Application" Tag="Exe"/>
                <ComboBoxItem Content="Windows Application" Tag="WinExe"/>
                <ComboBoxItem Content="Class Library" Tag="Library"/>
            </ComboBox>

            <!-- Code -->
            <TextBlock Text="CODE" Classes="section-header"/>
            <TextBlock Text="C# language version" Classes="prop-label"/>
            <ComboBox Name="LangVersionCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="Default (latest major)"/>
                <ComboBoxItem Content="Latest"/>
                <ComboBoxItem Content="preview"/>
                <ComboBoxItem Content="13"/>
                <ComboBoxItem Content="12"/>
                <ComboBoxItem Content="11"/>
                <ComboBoxItem Content="10"/>
                <ComboBoxItem Content="9.0"/>
                <ComboBoxItem Content="8.0"/>
                <ComboBoxItem Content="7.3"/>
            </ComboBox>

            <TextBlock Text="Nullable reference types" Classes="prop-label"/>
            <ComboBox Name="NullableCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="enable"/>
                <ComboBoxItem Content="disable"/>
                <ComboBoxItem Content="warnings"/>
                <ComboBoxItem Content="annotations"/>
            </ComboBox>

            <CheckBox Name="ImplicitUsingsCheck" Content="Enable implicit usings" Margin="0,4,0,10"/>
            <CheckBox Name="AllowUnsafeCheck"    Content="Allow unsafe code"       Margin="0,0,0,10"/>

            <!-- Application -->
            <TextBlock Text="APPLICATION" Classes="section-header"/>
            <TextBlock Text="Startup object" Classes="prop-label"/>
            <TextBox Name="StartupObjectBox" Watermark="(default)" Margin="0,0,0,12"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
