<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Insait_Edit_C_Sharp.Controls.ProjectProps.SigningPage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="28,16,28,28">
        <StackPanel Spacing="0" MaxWidth="720">

            <TextBlock Text="{DynamicResource ProjectProps.Sign.Header}" Classes="section-header" Margin="0,4,0,10"/>

            <CheckBox Name="SignAssemblyCheck"
                      Content="{DynamicResource ProjectProps.Sign.SignAssembly}"
                      Margin="0,0,0,18"/>

            <StackPanel Name="SignDetailsPanel" IsVisible="False" Spacing="0">
                <TextBlock Text="{DynamicResource ProjectProps.Sign.KeyFile}" Classes="prop-label"/>
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <TextBox Name="KeyFileBox" Grid.Column="0" Watermark="Path to .snk / .pfx file"/>
                    <Button Grid.Column="1" Name="BrowseKeyButton"
                            Content="{DynamicResource Common.Browse}" Classes="small-btn"
                            Margin="6,0,0,0" ToolTip.Tip="{DynamicResource ProjectProps.Sign.SelectKey}"/>
                </Grid>
                <CheckBox Name="DelaySignCheck"
                          Content="{DynamicResource ProjectProps.Sign.DelaySign}"
                          Margin="0,4,0,10"/>
                <Border Background="#FF1C1530" BorderBrush="#FF3A2E52" BorderThickness="1"
                        CornerRadius="7" Padding="14,10" Margin="0,8,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{DynamicResource ProjectProps.Sign.AboutTitle}"
                                   FontWeight="SemiBold" FontSize="12"
                                   Foreground="#FF9080A8"/>
                        <TextBlock FontSize="11" Foreground="#FF6A5888" TextWrapping="Wrap"
                                   Text="{DynamicResource ProjectProps.Sign.AboutText}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
