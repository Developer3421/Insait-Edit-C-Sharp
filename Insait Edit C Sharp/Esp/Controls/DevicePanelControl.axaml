<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
             x:Class="Insait_Edit_C_Sharp.Esp.Controls.DevicePanelControl">

    <UserControl.Resources>
        <Color x:Key="BgPrimary">#FF1F1A24</Color>
        <Color x:Key="BgSecondary">#FF2A2230</Color>
        <Color x:Key="BgTertiary">#FF352840</Color>
        <Color x:Key="BorderColor">#FF3E3050</Color>
        <Color x:Key="TextPrimary">#FFF0E8F4</Color>
        <Color x:Key="TextSecondary">#FF9E90B0</Color>
        <Color x:Key="TextMuted">#FF736886</Color>
        <Color x:Key="EspColor">#FF4FC3F7</Color>
        <Color x:Key="AccentGreen">#FFA6E3A1</Color>
        <Color x:Key="AccentRed">#FFF38BA8</Color>
        <Color x:Key="AccentOrange">#FFFFC09F</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
        <SolidColorBrush x:Key="EspColorBrush" Color="{StaticResource EspColor}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.esp-btn">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.esp-btn:pointerover">
            <Setter Property="Background" Value="#FF424258"/>
            <Setter Property="BorderBrush" Value="{StaticResource EspColorBrush}"/>
        </Style>
        <Style Selector="Button.esp-btn:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <Style Selector="Button.esp-btn TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource BgSecondaryBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
        <ScrollViewer>
            <StackPanel Margin="12" Spacing="16">
                
                <!-- Header -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📌" FontSize="16" FontFamily="Segoe UI Emoji, Segoe UI"/>
                        <TextBlock Text="nanoFramework Device" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource EspColorBrush}"/>
                    </StackPanel>
                    <TextBlock Text=".NET nanoFramework" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <Separator Background="{StaticResource BorderBrush}" Height="1"/>

                <!-- Device Connection -->
                <StackPanel Spacing="8">
                    <TextBlock Text="DEVICE" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" LetterSpacing="1"/>

                    <!-- COM Port Selection -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">
                        <ComboBox Name="ComPortComboBox" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BgTertiaryBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  CornerRadius="6" Padding="8,6" FontSize="12"/>
                        <Button Grid.Column="1" Classes="esp-btn" Content="🔄" Margin="4,0,0,0"
                                Width="36" Padding="4" Click="RefreshPorts_Click"
                                ToolTip.Tip="Refresh COM ports"/>
                    </Grid>

                    <!-- Connection Status -->
                    <Border Name="StatusBorder" Background="{StaticResource BgTertiaryBrush}" 
                            CornerRadius="6" Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Name="StatusIndicator" Width="8" Height="8" 
                                     Fill="{StaticResource AccentRedBrush}"/>
                            <TextBlock Name="StatusText" Text="Disconnected" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator Background="{StaticResource BorderBrush}" Height="1"/>

                <!-- Flash & Deploy Actions -->
                <StackPanel Spacing="8">
                    <TextBlock Text="ACTIONS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" LetterSpacing="1"/>

                    <Button Classes="esp-btn" Click="FlashFirmware_Click" Name="FlashButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚡" FontSize="14"/>
                            <TextBlock Text="Flash Firmware" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="esp-btn" Click="BuildProject_Click" Name="BuildButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔨" FontSize="14"/>
                            <TextBlock Text="Build" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="esp-btn" Click="DeployApp_Click" Name="DeployButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📤" FontSize="14"/>
                            <TextBlock Text="Deploy to Device" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="esp-btn" Click="BuildAndDeploy_Click" Name="BuildDeployButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🚀" FontSize="14"/>
                            <TextBlock Text="Build &amp; Deploy" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Classes="esp-btn" Click="EraseFlash_Click" Name="EraseButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🗑️" FontSize="14"/>
                            <TextBlock Text="Erase Flash" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Separator Background="{StaticResource BorderBrush}" Height="1"/>

                <!-- Serial Monitor -->
                <StackPanel Spacing="8">
                    <TextBlock Text="SERIAL MONITOR" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" LetterSpacing="1"/>

                    <!-- Baud Rate -->
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="Baud:" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                        <ComboBox Name="BaudRateComboBox" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BgTertiaryBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  CornerRadius="6" Padding="8,6" FontSize="12"/>
                    </Grid>

                    <Button Classes="esp-btn" Click="ToggleSerialMonitor_Click" Name="SerialMonitorButton">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📺" FontSize="14"/>
                            <TextBlock Name="SerialMonitorButtonText" Text="Open Serial Monitor" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Serial Output -->
                    <Border Background="{StaticResource BgPrimaryBrush}" CornerRadius="6" 
                            Padding="8" MinHeight="120" MaxHeight="250" Name="SerialOutputBorder"
                            IsVisible="False">
                        <ScrollViewer Name="SerialScrollViewer">
                            <TextBlock Name="SerialOutputText" FontSize="11" FontFamily="Consolas, Courier New"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       TextWrapping="Wrap" Text=""/>
                        </ScrollViewer>
                    </Border>

                    <!-- Serial Input -->
                    <Grid ColumnDefinitions="*,Auto" Name="SerialInputGrid" IsVisible="False">
                        <TextBox Name="SerialInputBox" FontSize="11" FontFamily="Consolas"
                                 Background="{StaticResource BgTertiaryBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 Watermark="Send command..." Padding="8,6"
                                 CornerRadius="6"/>
                        <Button Grid.Column="1" Classes="esp-btn" Content="➤" Margin="4,0,0,0"
                                Width="36" Padding="4" Click="SendSerialCommand_Click"/>
                    </Grid>
                </StackPanel>

                <Separator Background="{StaticResource BorderBrush}" Height="1"/>

                <!-- Board Info -->
                <StackPanel Spacing="4">
                    <TextBlock Text="BOARD INFO" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" LetterSpacing="1"/>
                    <TextBlock Name="BoardInfoText" Text="No board selected" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>

