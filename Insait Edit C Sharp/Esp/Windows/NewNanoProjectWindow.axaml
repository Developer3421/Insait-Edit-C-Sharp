<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="720"
        x:Class="Insait_Edit_C_Sharp.Esp.Windows.NewNanoProjectWindow"
        Title="New nanoFramework Project"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="780"
        MinHeight="680"
        Height="720"
        CanResize="False"
        FontFamily="Segoe UI, Arial, Tahoma">

    <Window.Resources>
        <Color x:Key="BgPrimary">#FF1F1A24</Color>
        <Color x:Key="BgSecondary">#FF2A2230</Color>
        <Color x:Key="BgTertiary">#FF352840</Color>
        <Color x:Key="BorderColor">#FF3E3050</Color>
        <Color x:Key="TextPrimary">#FFF0E8F4</Color>
        <Color x:Key="TextSecondary">#FF9E90B0</Color>
        <Color x:Key="AccentOrange">#FFFFC09F</Color>
        <Color x:Key="AccentPurple">#FFDCC4FF</Color>
        <Color x:Key="AccentGreen">#FFA6E3A1</Color>
        <Color x:Key="AccentBlue">#FF89B4FA</Color>
        <Color x:Key="EspColor">#FF4FC3F7</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="EspColorBrush" Color="{StaticResource EspColor}"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.window-control">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="#20DCC4FF"/>
        </Style>
        <Style Selector="Button.window-control.close:pointerover">
            <Setter Property="Background" Value="#30DCC4FF"/>
        </Style>

        <Style Selector="Button.template-btn">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.template-btn:pointerover">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
        <Style Selector="Button.template-btn.selected">
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Background" Value="#FF3E3050"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource EspColorBrush}"/>
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="{StaticResource EspColorBrush}"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-btn:pointerover">
            <Setter Property="Background" Value="#FF81D4FA"/>
        </Style>

        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>

        <Style Selector="Button.template-btn TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
    </Window.Styles>

    <Window.Background>
        <SolidColorBrush Color="{StaticResource BgPrimary}"/>
    </Window.Background>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="40,*,Auto">
            
            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#FF2D2438">
                <Grid ColumnDefinitions="*,Auto">
                    <Panel Grid.Column="0" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <TextBlock Text="📌" FontSize="14" Margin="0,0,8,0"
                                       FontFamily="Segoe UI Emoji, Segoe UI"/>
                            <TextBlock Text="New nanoFramework Project" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource EspColorBrush}"/>
                        </StackPanel>
                    </Panel>
                    <Button Grid.Column="1" Classes="window-control close" Click="CloseButton_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="24,20,24,16">
                <StackPanel Spacing="18">
                    
                    <!-- Header -->
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📌" FontSize="20" FontFamily="Segoe UI Emoji, Segoe UI"/>
                            <TextBlock Text=".NET nanoFramework" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource EspColorBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Create a C# project for ESP32 / nanoFramework" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Template Selection -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Select a template" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        
                        <Grid Name="TemplatePanel" ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Classes="template-btn selected" Name="BlankAppTemplate"
                                    Click="Template_Click" Tag="BlankApp">
                                <StackPanel>
                                    <TextBlock Text="📱" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Blank App" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                    <TextBlock Text="Empty app" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Classes="template-btn" Name="ClassLibTemplate"
                                    Click="Template_Click" Tag="ClassLibrary">
                                <StackPanel>
                                    <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Class Library" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                    <TextBlock Text="Reusable library" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Classes="template-btn" Name="GpioBlinkTemplate"
                                    Click="Template_Click" Tag="GpioBlink">
                                <StackPanel>
                                    <TextBlock Text="💡" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="GPIO Blink" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                    <TextBlock Text="LED blink" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" Classes="template-btn" Name="WiFiTemplate"
                                    Click="Template_Click" Tag="WiFiConnect">
                                <StackPanel>
                                    <TextBlock Text="📡" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Wi-Fi" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                    <TextBlock Text="Wi-Fi connect" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4" Classes="template-btn" Name="HttpTemplate"
                                    Click="Template_Click" Tag="HttpClient">
                                <StackPanel>
                                    <TextBlock Text="🌐" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="HTTP Client" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                    <TextBlock Text="HTTP requests" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="5" Classes="template-btn" Name="I2CTemplate"
                                    Click="Template_Click" Tag="I2CSensor">
                                <StackPanel>
                                    <TextBlock Text="🌡️" FontSize="24" HorizontalAlignment="Center"/>
                                    <TextBlock Text="I2C Sensor" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                    <TextBlock Text="Sensor reading" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Project Settings -->
                    <StackPanel Spacing="16">
                        <TextBlock Text="Configure your project" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" 
                              RowSpacing="12" ColumnSpacing="16">

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Project name"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ProjectNameBox"
                                     Text="MyEspProject" TextChanged="ProjectName_Changed"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Location"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto">
                                <TextBox Name="LocationBox" Text="" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Classes="secondary-btn" Content="Browse..."
                                        Click="BrowseLocation_Click"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Target Board"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Name="BoardComboBox"
                                      HorizontalAlignment="Stretch" SelectedIndex="0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Solution"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="8">
                                <CheckBox Name="AddToSolution" IsChecked="False"
                                          Foreground="{StaticResource TextPrimaryBrush}">
                                    <TextBlock Text="Add to existing solution"/>
                                </CheckBox>
                                <CheckBox Name="CreateNewSolution" IsChecked="True"
                                          Foreground="{StaticResource TextPrimaryBrush}">
                                    <TextBlock Text="Create new solution"/>
                                </CheckBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Info Box -->
                    <Border Background="#204FC3F7" CornerRadius="8" Padding="12,10"
                            BorderBrush="{StaticResource EspColorBrush}" BorderThickness="1" Opacity="0.8">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="ℹ️" FontSize="14"
                                       FontFamily="Segoe UI Emoji, Segoe UI"
                                       Foreground="{StaticResource EspColorBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="nanoff CLI (auto-installed)" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                <TextBlock Text="ESP32 via USB" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                <TextBlock Text="CP210x / CH340 driver" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </WrapPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" Padding="24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Name="ProjectPathPreview" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1" Classes="secondary-btn" Content="Cancel"
                            Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Grid.Column="2" Classes="primary-btn" Content="Create nanoFramework Project"
                            Name="CreateButton" Click="Create_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

