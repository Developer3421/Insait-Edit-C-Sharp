<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.Esp.Windows.LedPanelDesignerWindow"
        Title="LED Panel Designer"
        Width="1100"
        Height="800"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        SystemDecorations="None"
        Background="#FF1F1A24">
    
    <Window.Styles>
        <Style Selector="Button.led-btn">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.led-btn:pointerover">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="BorderBrush" Value="#FF4FC3F7"/>
        </Style>
        <Style Selector="Button.led-btn:pressed">
            <Setter Property="Background" Value="#FF4A3D58"/>
        </Style>
        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="#FFFFC09F"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-btn:pointerover">
            <Setter Property="Background" Value="#FFFFD4B8"/>
        </Style>
        <Style Selector="Button.color-swatch">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.color-swatch:pointerover">
            <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
        </Style>
        <Style Selector="Button.color-swatch.selected">
            <Setter Property="BorderBrush" Value="#FFFFC09F"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FF352840"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FF352840"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderBrush" Value="#FF3E3050"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
    </Window.Styles>

    <Border BorderBrush="#FF3E3050" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="36,*,Auto">
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#FF2D2438" CornerRadius="8,8,0,0" 
                    Name="TitleBar" PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="12,0">
                        <TextBlock Text="💡" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="LED Panel Designer" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#FF4FC3F7" VerticalAlignment="Center"/>
                        <TextBlock Text="— nanoFramework" FontSize="11" 
                                   Foreground="#FF9E90B0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Background="Transparent" Foreground="#FF9E90B0"
                                BorderThickness="0" Width="36" Height="36" Click="Minimize_Click">
                            <Image Source="avares://Insait Edit C Sharp/Icons/MinButton.png" Width="26" Height="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" Foreground="#FF9E90B0"
                                BorderThickness="0" Width="36" Height="36" Click="Close_Click">
                            <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" ColumnDefinitions="280,*">
                
                <!-- Left Panel: Settings -->
                <Border Grid.Column="0" Background="#FF2A2230" BorderBrush="#FF3E3050" BorderThickness="0,0,1,0">
                    <ScrollViewer>
                        <StackPanel Margin="12" Spacing="14">
                            
                            <!-- Panel Configuration -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="PANEL SIZE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FF736886" LetterSpacing="1"/>
                                <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="Rows" FontSize="11" Foreground="#FF9E90B0"/>
                                        <NumericUpDown Name="RowsInput" Value="8" Minimum="1" Maximum="64" 
                                                       ValueChanged="PanelSize_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Text="Columns" FontSize="11" Foreground="#FF9E90B0"/>
                                        <NumericUpDown Name="ColumnsInput" Value="8" Minimum="1" Maximum="64" 
                                                       ValueChanged="PanelSize_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Spacing="4">
                                        <TextBlock Text="Total LEDs" FontSize="11" Foreground="#FF9E90B0"/>
                                        <TextBlock Name="TotalLedsText" Text="64" FontSize="13" 
                                                   FontWeight="SemiBold" Foreground="#FFA6E3A1"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <Border Height="1" Background="#FF3E3050"/>

                            <!-- Hardware Settings -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="HARDWARE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FF736886" LetterSpacing="1"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="GPIO Pin" FontSize="11" Foreground="#FF9E90B0"/>
                                    <NumericUpDown Name="GpioPinInput" Value="18" Minimum="0" Maximum="39"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Strip Type" FontSize="11" Foreground="#FF9E90B0"/>
                                    <ComboBox Name="StripTypeCombo" HorizontalAlignment="Stretch" SelectedIndex="0">
                                        <ComboBoxItem Content="WS2812B"/>
                                        <ComboBoxItem Content="WS2811"/>
                                        <ComboBoxItem Content="SK6812"/>
                                        <ComboBoxItem Content="APA102"/>
                                        <ComboBoxItem Content="NeoPixel"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Brightness" FontSize="11" Foreground="#FF9E90B0"/>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Slider Name="BrightnessSlider" Minimum="0" Maximum="255" Value="50"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Name="BrightnessText" Text="50" Grid.Column="1" 
                                                   FontSize="11" Foreground="#FFF0E8F4" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" Width="30"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#FF3E3050"/>

                            <!-- Color Picker -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="PAINT COLOR" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FF736886" LetterSpacing="1"/>
                                
                                <!-- Current Color Preview -->
                                <Border Name="CurrentColorPreview" Background="#FFFF0000" 
                                        Height="32" CornerRadius="6"
                                        BorderBrush="#FF3E3050" BorderThickness="1"/>
                                
                                <!-- Color Palette -->
                                <WrapPanel Name="ColorPalette" Orientation="Horizontal">
                                    <!-- Colors populated in code-behind -->
                                </WrapPanel>
                                
                                <!-- Custom Color Input -->
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Text="#" FontSize="14" Foreground="#FF9E90B0" 
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBox Name="CustomColorInput" Watermark="FF0000" MaxLength="6"
                                             TextChanged="CustomColor_Changed"/>
                                </Grid>
                            </StackPanel>

                            <Border Height="1" Background="#FF3E3050"/>

                            <!-- Draw Mode -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="DRAW MODE" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FF736886" LetterSpacing="1"/>
                                <StackPanel Spacing="4">
                                    <RadioButton Name="DrawSingleRadio" Content="🖌️ Single LED" 
                                                 IsChecked="True" Foreground="#FFF0E8F4" GroupName="DrawMode"/>
                                    <RadioButton Name="DrawRowRadio" Content="↔️ Entire Row" 
                                                 Foreground="#FFF0E8F4" GroupName="DrawMode"/>
                                    <RadioButton Name="DrawColumnRadio" Content="↕️ Entire Column" 
                                                 Foreground="#FFF0E8F4" GroupName="DrawMode"/>
                                    <RadioButton Name="DrawEraseRadio" Content="🧹 Eraser" 
                                                 Foreground="#FFF0E8F4" GroupName="DrawMode"/>
                                    <RadioButton Name="DrawFillRadio" Content="🪣 Fill All" 
                                                 Foreground="#FFF0E8F4" GroupName="DrawMode"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#FF3E3050"/>

                            <!-- Quick Actions -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="ACTIONS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FF736886" LetterSpacing="1"/>
                                <Button Classes="led-btn" Content="🗑️ Clear All" Click="ClearAll_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Classes="led-btn" Content="🔄 Invert Colors" Click="InvertColors_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button Classes="led-btn" Content="🎲 Random Pattern" Click="RandomPattern_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <Border Height="1" Background="#FF3E3050"/>

                            <!-- Pattern Animation -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="ANIMATION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FF736886" LetterSpacing="1"/>
                                <Button Classes="led-btn" Content="📸 Capture Frame" Click="CaptureFrame_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Frame Delay (ms)" FontSize="11" Foreground="#FF9E90B0"/>
                                    <NumericUpDown Name="FrameDelayInput" Value="100" Minimum="10" Maximum="5000"
                                                   Increment="50"/>
                                </StackPanel>
                                <!-- Infinite Loop toggle -->
                                <CheckBox Name="InfiniteLoopCheck" Content="♾️ Infinite Loop"
                                          IsChecked="False" Foreground="#FFF0E8F4"
                                          IsCheckedChanged="InfiniteLoop_Changed"
                                          ToolTip.Tip="When enabled, the generated nanoFramework code runs the animation in an infinite while(true) loop"/>
                                <!-- Loop count (visible when Infinite Loop is OFF) -->
                                <StackPanel Name="LoopCountPanel" Spacing="4">
                                    <TextBlock Text="Loop Count" FontSize="11" Foreground="#FF9E90B0"/>
                                    <NumericUpDown Name="LoopCountInput" Value="10" Minimum="1" Maximum="9999"
                                                   Increment="1"/>
                                </StackPanel>
                                <TextBlock Name="FrameCountText" Text="Frames: 0" FontSize="11" 
                                           Foreground="#FF9E90B0"/>
                                <Button Classes="led-btn" Content="🗑️ Clear Frames" Click="ClearFrames_Click"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Right: LED Grid -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
                    
                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="#FF2A2230" Padding="8" 
                            BorderBrush="#FF3E3050" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="LED Display" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FF4FC3F7" VerticalAlignment="Center"/>
                            <Border Width="1" Height="20" Background="#FF3E3050" Margin="8,0"/>
                            <TextBlock Name="CoordInfoText" Text="Hover over LEDs" FontSize="11"
                                       Foreground="#FF9E90B0" VerticalAlignment="Center"/>
                            <Border Width="1" Height="20" Background="#FF3E3050" Margin="8,0"/>
                            <CheckBox Name="ShowGridLinesCheck" Content="Grid Lines" IsChecked="True"
                                      Foreground="#FFF0E8F4" FontSize="11" VerticalAlignment="Center"
                                      IsCheckedChanged="ShowGridLines_Changed"/>
                            <CheckBox Name="ShowCoordsCheck" Content="Coordinates" IsChecked="False"
                                      Foreground="#FFF0E8F4" FontSize="11" VerticalAlignment="Center"
                                      IsCheckedChanged="ShowGridLines_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- LED Grid Canvas -->
                    <Border Grid.Row="1" Background="#FF1A1A2A" Margin="8" CornerRadius="8"
                            BorderBrush="#FF3E3050" BorderThickness="1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas Name="LedCanvas" Background="Transparent" 
                                    Width="600" Height="600"
                                    PointerPressed="LedCanvas_PointerPressed"
                                    PointerMoved="LedCanvas_PointerMoved"
                                    PointerReleased="LedCanvas_PointerReleased"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Preview Bar -->
                    <Border Grid.Row="2" Background="#FF2A2230" Padding="8" 
                            BorderBrush="#FF3E3050" BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto" >
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="led-btn" Name="PreviewPlayButton" Click="PreviewPlay_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="▶️" FontSize="12"/>
                                        <TextBlock Name="PreviewPlayText" Text="Preview Pattern" 
                                                   VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="led-btn" Content="⏹ Stop" Click="PreviewStop_Click"/>
                            </StackPanel>
                            <TextBlock Name="PreviewStatusText" Text="" FontSize="11" 
                                       Foreground="#FF9E90B0" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Grid.Column="1"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <Button Classes="led-btn" Content="💾 Save Config" Click="SaveConfig_Click"/>
                                <Button Classes="led-btn" Content="📂 Load Config" Click="LoadConfig_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FF2A2230" Padding="12,10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Name="StatusText" Text="Ready — Design your LED pattern"
                                   FontSize="11" Foreground="#FF9E90B0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Classes="led-btn" Content="Cancel" Click="Cancel_Click"/>
                        <Button Classes="primary-btn" Name="GenerateCodeButton" Click="GenerateCode_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="⚡" FontSize="13"/>
                                <TextBlock Text="Generate nanoFramework Code" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

