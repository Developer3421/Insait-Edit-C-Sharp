<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.PublishProgressWindow"
        Title="Publishing..."
        Width="720"
        Height="520"
        MinWidth="500"
        MinHeight="350"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        SystemDecorations="None"
        Background="#FF1F1A24">

    <Window.Styles>
        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="Foreground" Value="#FFF0E8F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-button:pointerover">
            <Setter Property="Background" Value="#FF4A3D58"/>
        </Style>
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="#FF4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-button:pointerover">
            <Setter Property="Background" Value="#FF66BB6A"/>
        </Style>
        <Style Selector="Button.cancel-button">
            <Setter Property="Background" Value="#FFC0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.cancel-button:pointerover">
            <Setter Property="Background" Value="#FFE74C3C"/>
        </Style>
    </Window.Styles>

    <Border CornerRadius="10" Background="#FF1F1A24"
            BorderBrush="#FF3E3050" BorderThickness="1.5"
            ClipToBounds="True">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- ═══ Title Bar ═══ -->
            <Border Name="TitleBar" Grid.Row="0"
                    Background="#FF2A2230" Height="38"
                    CornerRadius="10,10,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center" Margin="14,0">
                        <TextBlock Text="📦" FontSize="15" FontFamily="Segoe UI Emoji"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="TitleText" Text="Publishing..."
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FFF0E8F4" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Name="CloseButton" Grid.Column="1"
                            Content="✕" FontSize="13"
                            Width="36" Height="38"
                            Background="Transparent" Foreground="#FF9E90B0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Cursor="Hand" BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- ═══ Main Content ═══ -->
            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" Margin="16,12,16,0">

                <!-- Status header -->
                <Border Grid.Row="0" Background="#FF2A2230" CornerRadius="8"
                        Padding="14,10" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Spinner / status icon -->
                        <TextBlock Name="StatusIcon" Grid.Column="0"
                                   Text="⏳" FontSize="20" FontFamily="Segoe UI Emoji"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Name="StatusText" Text="Preparing to publish..."
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FFF0E8F4"/>
                            <TextBlock Name="StatusDetail" Text=""
                                       FontSize="11" Foreground="#FF9E90B0"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Name="ElapsedTimeText" Grid.Column="2"
                                   Text="0:00" FontSize="12"
                                   Foreground="#FF9E90B0" VerticalAlignment="Center"
                                   FontFamily="Consolas, Monaco, monospace"/>
                    </Grid>
                </Border>

                <!-- Progress bar -->
                <Border Grid.Row="1" Background="#FF2A2230" CornerRadius="8"
                        Padding="14,8" Margin="0,0,0,10">
                    <Grid RowDefinitions="Auto,Auto">
                        <ProgressBar Name="PublishProgressBar" Grid.Row="0"
                                     IsIndeterminate="True"
                                     Height="6" CornerRadius="3"
                                     Foreground="#FFFFC09F"
                                     Background="#FF352840"/>
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                            <TextBlock Name="ProjectNameText" Grid.Column="0"
                                       Text="" FontSize="11"
                                       Foreground="#FF9E90B0"/>
                            <TextBlock Name="ProgressPercentText" Grid.Column="1"
                                       Text="" FontSize="11"
                                       Foreground="#FF9E90B0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Console output -->
                <Border Grid.Row="2" Background="#FF181420" CornerRadius="8"
                        BorderBrush="#FF2A2230" BorderThickness="1"
                        ClipToBounds="True">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Background="#FF222030" Padding="10,6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="📋 Console Output" FontSize="11"
                                           Foreground="#FF9E90B0"
                                           VerticalAlignment="Center"/>
                                <Button Name="ClearOutputButton" Grid.Column="1"
                                        Content="🗑 Clear" FontSize="10"
                                        Background="Transparent"
                                        Foreground="#FF9E90B0"
                                        Padding="6,2" Cursor="Hand"
                                        BorderThickness="0"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Name="OutputScrollViewer" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <SelectableTextBlock Name="OutputText"
                                       Text=""
                                       FontFamily="Consolas, Monaco, 'Courier New', monospace"
                                       FontSize="11.5"
                                       Foreground="#FFD0C8E0"
                                       Margin="10,6"
                                       TextWrapping="Wrap"
                                       SelectionBrush="#664FC3F7"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ Bottom Bar ═══ -->
            <Border Grid.Row="2" Background="#FF2A2230" Padding="14,10"
                    CornerRadius="0,0,10,10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Result info (visible after completion) -->
                    <StackPanel Name="ResultInfoPanel" Grid.Column="0"
                                Orientation="Horizontal" Spacing="12"
                                IsVisible="False" VerticalAlignment="Center">
                        <TextBlock Name="OutputSizeText" Text=""
                                   FontSize="11" Foreground="#FF9E90B0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Name="OutputPathText" Text=""
                                   FontSize="11" Foreground="#FF7B8DCF"
                                   VerticalAlignment="Center"
                                   TextDecorations="Underline"
                                   Cursor="Hand"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <!-- Cancel button (during publish) -->
                        <Button Name="CancelPublishButton" Content="⏹ Cancel"
                                Classes="cancel-button"/>
                        
                        <!-- Open Folder button (after publish) -->
                        <Button Name="OpenFolderButton" Content="📂 Open Folder"
                                Classes="primary-button" IsVisible="False"/>

                        <!-- Close button -->
                        <Button Name="CloseWindowButton" Content="Close"
                                Classes="action-button"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>

