<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Insait_Edit_C_Sharp.GeminiLanguageNameWindow"
        Title="Custom Translation — Step 1"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="500" Height="320"
        CanResize="False" ShowInTaskbar="False"
        Background="#FF1F1A24">
    <Window.Styles>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#FF2A2230"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="SelectionBrush" Value="#60FFC09F"/>
            <Setter Property="SelectionForegroundBrush" Value="#FF1F1A24"/>
            <Setter Property="CaretBrush" Value="#FFF0E8F4"/>
        </Style>
    </Window.Styles>
    <Border BorderBrush="#FF3E3050" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="36,*">
            <Border Grid.Row="0" Background="#FF2D2438" CornerRadius="8,8,0,0"
                    Name="TitleBar" PointerPressed="TitleBar_PointerPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{DynamicResource Gemini.Lang.Title}"
                               FontSize="13" FontWeight="SemiBold" Foreground="#FFF0E8F4"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <Button Grid.Column="1" Name="CloseButton" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0" Width="36" Height="36" Padding="0" Cursor="Hand">
                        <TextBlock Text="✕" Foreground="#FFF0E8F4" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="24,20,24,20" Spacing="14">
                <TextBlock Text="{DynamicResource Gemini.Lang.Prompt}"
                           FontSize="13" Foreground="#FFF0E8F4" TextWrapping="Wrap"/>
                <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource Gemini.Lang.FieldLabel}" FontSize="12" FontWeight="SemiBold" Foreground="#FFFFC09F"/>
                    <TextBox x:Name="LanguageNameBox"
                             Watermark="e.g. French, Japanese, Español, Polski..."
                             FontSize="14"
                             Background="#FF2A2230" Foreground="#FFF0E8F4"
                             BorderBrush="#FF3E3050" BorderThickness="1" CornerRadius="4" Padding="8,6"/>
                </StackPanel>
                <Border Background="#FF2A2230" CornerRadius="6" Padding="12,10">
                    <TextBlock FontSize="12" Foreground="#FF9E90B0" TextWrapping="Wrap"
                               Text="{DynamicResource Gemini.Lang.Hint}"/>
                </Border>
                <Grid ColumnDefinitions="*,12,*">
                    <Button Grid.Column="0" Click="CancelButton_Click"
                            Background="#FF3D3050" Foreground="#FFF0E8F4" BorderThickness="0"
                            CornerRadius="6" Padding="16,8" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                        <TextBlock Text="{DynamicResource Gemini.Lang.Cancel}" FontSize="13"/>
                    </Button>
                    <Button Grid.Column="2" Click="NextButton_Click"
                            Background="#FF7C3AED" Foreground="#FFF0E8F4" BorderThickness="0"
                            CornerRadius="6" Padding="16,8" Cursor="Hand"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                        <TextBlock Text="{DynamicResource Gemini.Lang.Next}" FontSize="13"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>

