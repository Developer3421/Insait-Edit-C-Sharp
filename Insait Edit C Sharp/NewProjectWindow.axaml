<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Insait_Edit_C_Sharp"
        d:DesignWidth="740" d:DesignHeight="700"
        x:Class="Insait_Edit_C_Sharp.NewProjectWindow"
        Title="New Project"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        Width="740"
        Height="700"
        CanResize="False"
        FontFamily="Segoe UI, Arial, Tahoma">

    <Window.Resources>
        <Color x:Key="BgPrimary">#FF1F1A24</Color>
        <Color x:Key="BgSecondary">#FF2A2230</Color>
        <Color x:Key="BgTertiary">#FF352840</Color>
        <Color x:Key="BorderColor">#FF3E3050</Color>
        <Color x:Key="TextPrimary">#FFF0E8F4</Color>
        <Color x:Key="TextSecondary">#FF9E90B0</Color>
        <!-- Light peach-orange accent -->
        <Color x:Key="AccentOrange">#FFFFC09F</Color>
        <Color x:Key="AccentPurple">#FFDCC4FF</Color>
        <Color x:Key="AccentGreen">#FFA6E3A1</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiary}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.window-control">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="#30FFFFFF"/>
        </Style>
        <Style Selector="Button.window-control.close:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>

        <Style Selector="Button.template-btn">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.template-btn:pointerover">
            <Setter Property="Background" Value="#FF3E3050"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>
        <Style Selector="Button.template-btn.selected">
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Background" Value="#FF3E3050"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
        </Style>

        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}"/>
            <Setter Property="Foreground" Value="#FF1F1A24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.primary-btn:pointerover">
            <Setter Property="Background" Value="#FFFFD4B8"/>
        </Style>
        <Style Selector="Button.primary-btn:disabled">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <Style Selector="Button.secondary-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.secondary-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource BgTertiaryBrush}"/>
        </Style>
        
        <!-- Emoji icons style - preserve natural colors -->
        <Style Selector="Button.template-btn TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, Arial"/>
        </Style>
    </Window.Styles>

    <Window.Background>
        <SolidColorBrush Color="{StaticResource BgPrimary}"/>
    </Window.Background>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
        <Grid RowDefinitions="40,*,Auto">
            
            <!-- Title Bar - Gray -->
            <Grid Grid.Row="0" Background="#FF3C3C3C">
                <Grid ColumnDefinitions="*,Auto">
                    <Panel Grid.Column="0" Background="Transparent" PointerPressed="TitleBar_PointerPressed">
                        <TextBlock Name="TitleBarText" Text="New Project" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentOrangeBrush}"
                                   VerticalAlignment="Center" Margin="16,0"/>
                    </Panel>
                    <Button Grid.Column="1" Classes="window-control close" Click="CloseButton_Click">
                        <Image Source="avares://Insait Edit C Sharp/Icons/CloseButton.png" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="24">
                <StackPanel Spacing="24">
                    
                    <!-- Template Selection -->
                    <StackPanel Spacing="12">
                        <TextBlock Name="SelectTemplateText" Text="Select a template" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        
                        <WrapPanel Orientation="Horizontal">
                            <Button Classes="template-btn selected" Name="ConsoleTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="console">
                                <StackPanel Width="140">
                                    <TextBlock Text="💻" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Console App" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="A project for creating a command-line application"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="ClassLibTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="classlib">
                                <StackPanel Width="140">
                                    <TextBlock Text="📚" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Class Library" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="A project for creating a class library (.dll)"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="AvaloniaTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="avalonia">
                                <StackPanel Width="140">
                                    <TextBlock Text="🖼️" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avalonia App" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="Cross-platform UI app with Avalonia"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="WebApiTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="webapi">
                                <StackPanel Width="140">
                                    <TextBlock Text="🌐" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ASP.NET Web API" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="A project for creating RESTful HTTP services"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Classes="template-btn" Name="NanoTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="nano">
                                <StackPanel Width="140">
                                    <TextBlock Text="🔌" FontSize="32" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                                    <TextBlock Text="nanoFramework" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text=".NET nanoFramework for ESP32 / IoT"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="FSharpConsoleTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="fsharp-console">
                                <StackPanel Width="140">
                                    <TextBlock Text="🔷" FontSize="32" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                                    <TextBlock Text="F# Console App" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="Standard F# console application"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="FSharpEmptyTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="fsharp-empty">
                                <StackPanel Width="140">
                                    <TextBlock Text="🔹" FontSize="32" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                                    <TextBlock Text="F# Empty Project" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="Minimal F# class library (empty)"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="WinFormsTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="winforms">
                                <StackPanel Width="140">
                                    <TextBlock Text="🪟" FontSize="32" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                                    <TextBlock Text="Windows Forms" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="Windows Forms desktop app (WinForms)"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="CSharpEmptyTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="csharp-empty">
                                <StackPanel Width="140">
                                    <TextBlock Text="📄" FontSize="32" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                                    <TextBlock Text="C# Empty Project" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="Minimal C# project with no files"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Classes="template-btn" Name="FSharpSafeStackTemplate" Margin="0,0,12,12"
                                    Click="Template_Click" Tag="fsharp-safestack">
                                <StackPanel Width="140">
                                    <TextBlock Text="🔷🌐" FontSize="32" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji, Segoe UI"/>
                                    <TextBlock Text="F# SAFE Stack" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,8,0,4"/>
                                    <TextBlock Text="Full-stack F# web app (Saturn + Fable + Elmish)"
                                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Project Settings -->
                    <StackPanel Spacing="16">
                        <TextBlock Name="ConfigureText" Text="Configure your project" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" 
                              RowSpacing="12" ColumnSpacing="16">
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Name="ProjectNameLabel" Text="Project name"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Name="ProjectNameBox" 
                                     Text="MyProject" TextChanged="ProjectName_Changed"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Name="LocationLabel" Text="Location"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto">
                                <TextBox Name="LocationBox" Text="" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Name="BrowseButton" Classes="secondary-btn" Content="Browse..." 
                                        Click="BrowseLocation_Click"/>
                            </Grid>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Name="SolutionNameLabel" Text="Solution name"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Name="SolutionNameBox" Text="MyProject"/>
                        </Grid>
                        
                        <!-- Solution Format -->
                        <StackPanel Spacing="6" Margin="0,8,0,0">
                            <TextBlock Name="SolutionFormatLabel" Text="Solution file format" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <RadioButton Name="SlnxFormat" IsChecked="True"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             IsCheckedChanged="SolutionFormat_Changed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="📄" FontFamily="Segoe UI Emoji, Segoe UI, Arial"/>
                                        <StackPanel>
                                            <TextBlock Text=".slnx" FontWeight="SemiBold"/>
                                            <TextBlock Text="Modern XML format (.NET 10+)" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Name="SlnFormat"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             IsCheckedChanged="SolutionFormat_Changed">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="📋" FontFamily="Segoe UI Emoji, Segoe UI, Arial"/>
                                        <StackPanel>
                                            <TextBlock Text=".sln" FontWeight="SemiBold"/>
                                            <TextBlock Text="Legacy Visual Studio format" FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </StackPanel>

                        <!-- Options -->
                        <StackPanel Spacing="8" Margin="0,4,0,0">
                            <CheckBox Name="CreateSolutionDir" IsChecked="True"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock Name="PlaceSameDirText" Text="Place solution and project in the same directory"/>
                            </CheckBox>
                            <CheckBox Name="CreateGitRepo" IsChecked="True"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock Name="CreateGitRepoText" Text="Create Git repository"/>
                            </CheckBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondaryBrush}" Padding="24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Name="ProjectPathPreview" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="1" Name="CancelButton" Classes="secondary-btn" Content="Cancel" 
                            Margin="0,0,12,0" Click="Cancel_Click"/>
                    <Button Grid.Column="2" Name="CreateButton" Classes="primary-btn" Content="Create" 
                            Click="Create_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

