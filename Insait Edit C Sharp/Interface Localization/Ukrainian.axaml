    <!-- ── CLI Usage strings ─────────────────────────────────────── -->
    <x:String x:Key="Cli.Usage.Create">Використання: create &lt;шлях&gt; [--content &lt;вміст&gt;] [--dir]</x:String>
    <x:String x:Key="Cli.Usage.Touch">Використання: touch &lt;шлях&gt;</x:String>
    <x:String x:Key="Cli.Usage.Mkdir">Використання: mkdir &lt;шлях&gt;</x:String>
    <x:String x:Key="Cli.Usage.Template">Використання: template &lt;назва-шаблону&gt; &lt;шлях&gt;&#10;&#10;Доступні шаблони:&#10;  class - C# клас&#10;  interface - C# інтерфейс&#10;  record - C# запис&#10;  enum - C# перелік&#10;  service - C# сервіс&#10;  viewmodel - MVVM ViewModel&#10;  html - HTML файл&#10;  json - JSON файл&#10;  xml - XML файл</x:String>
    <x:String x:Key="Cli.Usage.Delete">Використання: delete &lt;шлях&gt; [--force]</x:String>
    <x:String x:Key="Cli.Usage.Rmdir">Використання: rmdir &lt;шлях&gt; [--force]</x:String>
    <x:String x:Key="Cli.Usage.Rename">Використання: rename &lt;старий-шлях&gt; &lt;нова-назва&gt;</x:String>
    <x:String x:Key="Cli.Usage.Mv">Використання: mv &lt;джерело&gt; &lt;призначення&gt;</x:String>
    <x:String x:Key="Cli.Usage.Copy">Використання: copy &lt;джерело&gt; &lt;призначення&gt;</x:String>
    <x:String x:Key="Cli.Usage.Write">Використання: write &lt;шлях&gt; &lt;вміст&gt;</x:String>
    <x:String x:Key="Cli.Usage.Append">Використання: append &lt;шлях&gt; &lt;вміст&gt;</x:String>
    <x:String x:Key="Cli.Usage.Read">Використання: read &lt;шлях&gt;</x:String>
    <x:String x:Key="Cli.Usage.Cd">Використання: cd &lt;шлях&gt;</x:String>
    <x:String x:Key="Cli.Usage.Find">Використання: find &lt;шаблон&gt; [--path &lt;тека&gt;]</x:String>
    <x:String x:Key="Cli.Usage.Search">Використання: search &lt;текст&gt; [--path &lt;тека&gt;] [--ext &lt;розширення&gt;]</x:String>
    <x:String x:Key="Cli.Usage.Info">Використання: info &lt;шлях&gt;</x:String>
