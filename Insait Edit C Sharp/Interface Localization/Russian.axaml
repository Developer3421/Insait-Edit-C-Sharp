    <!-- ── CLI Usage strings ─────────────────────────────────────── -->
    <x:String x:Key="Cli.Usage.Create">Использование: create &lt;путь&gt; [--content &lt;содержимое&gt;] [--dir]</x:String>
    <x:String x:Key="Cli.Usage.Touch">Использование: touch &lt;путь&gt;</x:String>
    <x:String x:Key="Cli.Usage.Mkdir">Использование: mkdir &lt;путь&gt;</x:String>
    <x:String x:Key="Cli.Usage.Template">Использование: template &lt;имя-шаблона&gt; &lt;путь&gt;&#10;&#10;Доступные шаблоны:&#10;  class - C# класс&#10;  interface - C# интерфейс&#10;  record - C# запись&#10;  enum - C# перечисление&#10;  service - C# сервис&#10;  viewmodel - MVVM ViewModel&#10;  html - HTML файл&#10;  json - JSON файл&#10;  xml - XML файл</x:String>
    <x:String x:Key="Cli.Usage.Delete">Использование: delete &lt;путь&gt; [--force]</x:String>
    <x:String x:Key="Cli.Usage.Rmdir">Использование: rmdir &lt;путь&gt; [--force]</x:String>
    <x:String x:Key="Cli.Usage.Rename">Использование: rename &lt;старый-путь&gt; &lt;новое-имя&gt;</x:String>
    <x:String x:Key="Cli.Usage.Mv">Использование: mv &lt;источник&gt; &lt;назначение&gt;</x:String>
    <x:String x:Key="Cli.Usage.Copy">Использование: copy &lt;источник&gt; &lt;назначение&gt;</x:String>
    <x:String x:Key="Cli.Usage.Write">Использование: write &lt;путь&gt; &lt;содержимое&gt;</x:String>
    <x:String x:Key="Cli.Usage.Append">Использование: append &lt;путь&gt; &lt;содержимое&gt;</x:String>
    <x:String x:Key="Cli.Usage.Read">Использование: read &lt;путь&gt;</x:String>
    <x:String x:Key="Cli.Usage.Cd">Использование: cd &lt;путь&gt;</x:String>
    <x:String x:Key="Cli.Usage.Find">Использование: find &lt;шаблон&gt; [--path &lt;папка&gt;]</x:String>
