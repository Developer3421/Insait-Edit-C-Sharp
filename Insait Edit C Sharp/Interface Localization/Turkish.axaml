    <!-- ── CLI Usage strings ─────────────────────────────────────── -->
    <x:String x:Key="Cli.Usage.Create">Kullanım: create &lt;yol&gt; [--content &lt;içerik&gt;] [--dir]</x:String>
    <x:String x:Key="Cli.Usage.Touch">Kullanım: touch &lt;yol&gt;</x:String>
    <x:String x:Key="Cli.Usage.Mkdir">Kullanım: mkdir &lt;yol&gt;</x:String>
    <x:String x:Key="Cli.Usage.Template">Kullanım: template &lt;şablon-adı&gt; &lt;yol&gt;&#10;&#10;Mevcut şablonlar:&#10;  class - C# sınıf&#10;  interface - C# arayüz&#10;  record - C# kayıt&#10;  enum - C# numaralandırma&#10;  service - C# servis&#10;  viewmodel - MVVM ViewModel&#10;  html - HTML dosyası&#10;  json - JSON dosyası&#10;  xml - XML dosyası</x:String>
    <x:String x:Key="Cli.Usage.Delete">Kullanım: delete &lt;yol&gt; [--force]</x:String>
    <x:String x:Key="Cli.Usage.Rmdir">Kullanım: rmdir &lt;yol&gt; [--force]</x:String>
    <x:String x:Key="Cli.Usage.Rename">Kullanım: rename &lt;eski-yol&gt; &lt;yeni-ad&gt;</x:String>
    <x:String x:Key="Cli.Usage.Mv">Kullanım: mv &lt;kaynak&gt; &lt;hedef&gt;</x:String>
    <x:String x:Key="Cli.Usage.Copy">Kullanım: copy &lt;kaynak&gt; &lt;hedef&gt;</x:String>
    <x:String x:Key="Cli.Usage.Write">Kullanım: write &lt;yol&gt; &lt;içerik&gt;</x:String>
    <x:String x:Key="Cli.Usage.Append">Kullanım: append &lt;yol&gt; &lt;içerik&gt;</x:String>
    <x:String x:Key="Cli.Usage.Read">Kullanım: read &lt;yol&gt;</x:String>
    <x:String x:Key="Cli.Usage.Cd">Kullanım: cd &lt;yol&gt;</x:String>
    <x:String x:Key="Cli.Usage.Find">Kullanım: find &lt;desen&gt; [--path &lt;dizin&gt;]</x:String>
    <x:String x:Key="Cli.Usage.Search">Kullanım: search &lt;metin&gt; [--path &lt;dizin&gt;] [--ext &lt;uzantı&gt;]</x:String>
    <x:String x:Key="Cli.Usage.Info">Kullanım: info &lt;yol&gt;</x:String>
    <x:String x:Key="Cli.Usage.Exists">Kullanım: exists &lt;yol&gt;</x:String>
    <x:String x:Key="Cli.Usage.GhTask">Kullanım: gh-t "&lt;görev açıklaması&gt;"</x:String>
    <x:String x:Key="Cli.Usage.GhModel">Kullanım: gh-m &lt;model adı&gt;&#10;&#10;Örnek:&#10;  gh-m gpt-4o</x:String>

